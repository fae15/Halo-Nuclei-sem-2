Notebook[{
Cell["Fitting Gaussians to Modified Woods-Saxon Potential", "Text",
 CellChangeTimes->{{3.9717813080617466`*^9, 
  3.9717813269740906`*^9}},ExpressionUUID->"127c7655-d6f2-a14e-8e9e-\
5e1325e6a568"],

Cell["defining global constants", "Text",
 CellChangeTimes->{{3.9717813357840767`*^9, 
  3.971781342980608*^9}},ExpressionUUID->"4bf4a626-d70b-8046-bbb2-\
b20bfdaffe28"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DIFFUSIVITY", "=", "0.6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R0", " ", "=", " ", "1.2"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"[", "fm", "]"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Ac", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"number", " ", "of", " ", "core", " ", "nucleons"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"J", " ", "=", " ", "0.5"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"total", " ", "angular", " ", "momentum"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"l", " ", "=", " ", "0"}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"orbital", " ", "angular", " ", "momentum"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"VLS", " ", "=", " ", 
    RowBox[{"-", "21"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"[", "MeV", "]"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rEps", " ", "=", " ", "0.00001"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"small", " ", "r", " ", "parameter"}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"rVals", " ", "=", " ", 
   RowBox[{"Subdivide", "[", 
    RowBox[{"1.*^-5", ",", " ", "15", ",", " ", "10000"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V0", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "11.39"}], ")"}], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "l"}]}], " ", "-", " ", "51.13"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Rcore", " ", "=", " ", 
   RowBox[{"R0", "*", 
    RowBox[{"Ac", "^", 
     RowBox[{"(", 
      RowBox[{"1", "/", "3"}], ")"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.971781382647999*^9, 3.9717814911637154`*^9}, {
   3.9717817015976963`*^9, 3.971781701926626*^9}, 3.971786238027296*^9, 
   3.9717864137744102`*^9, 3.9717865039199715`*^9, {3.971786581259716*^9, 
   3.971786599063286*^9}, {3.9717867830573273`*^9, 3.971786837972044*^9}, 
   3.9717869056857033`*^9, 3.9717869592553673`*^9, 3.9717871659693966`*^9, 
   3.9717873531301575`*^9, 3.9717873890160465`*^9, {3.9717874814414043`*^9, 
   3.971787502450327*^9}, {3.9717875409897976`*^9, 3.9717875411144905`*^9}, {
   3.9717876663730774`*^9, 3.97178768267535*^9}, {3.971787724736683*^9, 
   3.9717877262120953`*^9}, {3.9717878173800163`*^9, 3.971787832628868*^9}, {
   3.9833540156272182`*^9, 3.9833540217210503`*^9}},
 CellLabel->
  "In[180]:=",ExpressionUUID->"df6fc313-1da8-9f4e-9e47-100e474845ad"],

Cell["defining functions", "Text",
 CellChangeTimes->{{3.971781513547207*^9, 
  3.9717815176956425`*^9}},ExpressionUUID->"eb7e491d-bca6-094c-9f70-\
fb17d12b931e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "generate", " ", "the", " ", "geometric", " ", "betas", " ", "for", " ", 
      "use", " ", "in", " ", "our", " ", "gaussians", "\[IndentingNewLine]", 
      RowBox[{"NOTE", ":", " ", 
       RowBox[{
       "the", " ", "success", " ", "of", " ", "this", " ", "method", " ", 
        "is", " ", "VERY", " ", "dependent", " ", "on", " ", "the", " ", 
        "initial", " ", "values", " ", "of", " ", "r1", " ", "and", " ", 
        RowBox[{"a", "!!"}], " ", "good", " ", "choices", " ", "seem", " ", 
        "to", " ", "be", " ", "a"}]}]}], "=", 
     RowBox[{
      RowBox[{"1.4", "ish", " ", "for", " ", "l"}], "=", "0"}]}], ",", " ", 
    RowBox[{
     RowBox[{"and", " ", "a"}], "=", 
     RowBox[{
      RowBox[{"1.3", "ish", " ", "for", " ", "l"}], "=", 
      RowBox[{
       RowBox[{
       "1.", " ", "i", " ", "figure", " ", "this", " ", "out", " ", "by", " ",
         "finding", " ", "the", " ", "maximum", " ", "difference", " ", 
        "between", " ", "our", " ", "estimated", " ", "gaussian", " ", 
        "potential", " ", "and", " ", "the", " ", "real", " ", "woods"}], "-", 
       RowBox[{"saxon", " ", "later", " ", 
        RowBox[{"(", 
         RowBox[{
         "once", " ", "the", " ", "curve", " ", "fit", " ", "has", " ", 
          "been", " ", "done"}], ")"}]}]}]}]}], ",", " ", 
    RowBox[{
    "and", " ", "choosing", " ", "an", " ", "a", " ", "which", " ", "makes", " ",
      "this", " ", 
     RowBox[{"small", ".", " ", "there"}], " ", "is", " ", "Absolutely", " ", 
     "a", " ", "better", " ", "more", " ", "numeric", " ", "way", " ", "to", " ",
      "pick", " ", "a", " ", "but", " ", "this", " ", "works", " ", "for", " ",
      "now", " ", "so", " ", 
     RowBox[{"i", "'"}], "m", " ", "sticking", " ", "with", " ", "it"}]}], 
   "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"generateBetas", "[", 
      RowBox[{"numGaussians_Integer", ",", " ", 
       RowBox[{"r1_", ":", " ", "1.8"}], ",", " ", 
       RowBox[{"a_", ":", " ", "1.4"}]}], "]"}], " ", ":=", "  ", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", "rn", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"rn", " ", "=", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"r1", "*", 
            RowBox[{"a", "^", "i"}]}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"i", ",", " ", "0", ",", " ", 
             RowBox[{"numGaussians", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}],
         ";", "\n", "  ", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"rn", "^", "2"}], ")"}]}]}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.9717815296371098`*^9, 3.971781588904537*^9}, {
   3.9717824489959164`*^9, 3.9717826128909187`*^9}, {3.971786056808174*^9, 
   3.9717862346758957`*^9}, 3.9717862863447227`*^9, 3.9717864180109653`*^9, {
   3.9717871475616894`*^9, 3.971787212198942*^9}, {3.971787302434353*^9, 
   3.971787320629219*^9}},
 CellLabel->
  "In[190]:=",ExpressionUUID->"f0cd57f8-e3d2-6f46-9da0-4a48512db0f2"],

Cell["\<\
add the functions to define the woods-saxon potential without the spin-orbit \
correction\
\>", "Text",
 CellChangeTimes->{{3.97178161369598*^9, 
  3.9717816350497265`*^9}},ExpressionUUID->"9fdcf078-5b0e-0945-8643-\
f8679ee6f2c8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noSpinOrbitPotential", "[", 
     RowBox[{"rList_List", ",", " ", 
      RowBox[{"orbAng_", ":", " ", "l"}], ",", " ", 
      RowBox[{"diffusivity_", ":", " ", "DIFFUSIVITY"}], ",", " ", "\n", 
      "   ", 
      RowBox[{"r0_", ":", " ", "R0"}], ",", " ", 
      RowBox[{"numCoreNucleons_", ":", " ", "Ac"}]}], "]"}], " ", ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"V0", ",", " ", "Rcore"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"V0", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "11.39"}], ")"}], "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "orbAng"}]}], " ", "-", " ", 
         "51.13"}]}], ";", "\n", "  ", 
       RowBox[{"Rcore", " ", "=", " ", 
        RowBox[{"r0", "*", 
         RowBox[{"numCoreNucleons", "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "3"}], ")"}]}]}]}], ";", "\n", "  ", 
       RowBox[{"V0", "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"rList", " ", "-", " ", "Rcore"}], ")"}], "/", 
            "diffusivity"}], "]"}], " ", "+", " ", "1"}], ")"}]}]}]}], "\n", 
     " ", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"analyticWS", " ", "=", " ", 
   RowBox[{"noSpinOrbitPotential", "[", "rVals", "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.971781650890833*^9, 3.971781664425049*^9}, {
  3.9717817260065937`*^9, 3.9717817930247135`*^9}, {3.9717818445943813`*^9, 
  3.9717818474652233`*^9}},
 CellLabel->
  "In[191]:=",ExpressionUUID->"1dfa759e-fc1a-a94b-b6c9-741631fdf5ee"],

Cell["\<\
calculate the spin-orbit term and add it to our analytic potential\
\>", "Text",
 CellChangeTimes->{{3.9717818162568665`*^9, 
  3.971781828639221*^9}},ExpressionUUID->"6a46f4ef-f359-724c-af8f-\
9f57d794b37a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "calculate", " ", "the", " ", "derivative", " ", "for", " ", "use", " ", 
     "in", " ", "the", " ", "spin"}], "-", 
    RowBox[{"orbit", " ", "term"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"expTerm", " ", "=", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"rVals", " ", "-", " ", "Rcore"}], ")"}], "/", 
       "DIFFUSIVITY"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"centralWS", " ", "=", " ", 
     RowBox[{"V0", "/", 
      RowBox[{"(", 
       RowBox[{"expTerm", " ", "+", " ", "1"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dcentralDR", " ", "=", " ", 
     RowBox[{"V0", "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"1", "/", "DIFFUSIVITY"}], ")"}]}], "*", 
        RowBox[{"expTerm", "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"expTerm", " ", "+", " ", "1"}], ")"}], "^", "2"}]}]}], 
       ")"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"add", " ", "a", " ", "spin"}], "-", 
      RowBox[{
      "orbit", " ", "term", " ", "complete", " ", "with", " ", "a", " ", 
       "smooth", " ", "regularisation", " ", "when", " ", "r", " ", "tends", " ",
        "to", " ", "zero", "\[IndentingNewLine]", "this", " ", "method", " ", 
       "inspired", " ", "by", " ", "this", " ", "phd", " ", "thesis", " ", 
       "i", " ", 
       RowBox[{"found", ":", " ", "https", ":"}]}]}], "//", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"math", ".", "ucr", ".", "edu"}], "/", "home"}], "/", 
         "baez"}], "/", "physical"}], "/", "sarang_gopalakrishnan"}], 
      RowBox[{"_thesis", ".", "pdf"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
        "mentions", " ", "in", " ", "the", " ", "introduction", " ", "that", " ",
          "smoothing", " ", "fixes", " ", "most", " ", "problems", " ", 
         "caused", " ", "by", " ", "r", " ", "blowing", " ", "up", " ", 
         "near", " ", "zero"}], ",", " ", 
        RowBox[{
         RowBox[{
         "would", " ", "probs", " ", "have", " ", "to", " ", "check", " ", 
          "this", " ", "more", " ", "thoroughly", " ", "for", " ", "woods"}], 
         "-", 
         RowBox[{
         "saxon", " ", "applications", " ", "but", " ", "it", " ", "seems", " ",
           "to", " ", "work", " ", 
          RowBox[{"here", "?"}]}]}]}], ")"}]}]}], "\[IndentingNewLine]", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"invRSmooth", "[", "r_", "]"}], " ", ":=", " ", 
     RowBox[{"r", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"r", "^", "2"}], " ", "+", " ", 
        RowBox[{"rEps", "^", "2"}]}], ")"}]}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"goes", " ", "to", " ", "0", " ", "as", " ", "r"}], "->", "0"}],
      ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"~", "1"}], "/", "r"}], " ", "for", " ", "r"}], " ", ">>", 
      " ", "rEps"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"invRVec", " ", "=", " ", 
     RowBox[{"invRSmooth", " ", "/@", " ", "rVals"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "applying", " ", "this", " ", "to", " ", "our", " ", "r", " ", "values", " ",
      "array", " ", "from", " ", "earlier"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<rEps = \>\"", ",", "rEps"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<invRVec min,max = \>\"", ",", 
      RowBox[{"Min", "[", "invRVec", "]"}], ",", "\"\<, \>\"", ",", 
      RowBox[{"Max", "[", "invRVec", "]"}]}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spinCouplingTerm", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"J", "*", 
          RowBox[{"(", 
           RowBox[{"J", " ", "+", " ", "1"}], ")"}]}], ")"}], "/", "2"}], 
       ")"}], " ", "-", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"l", "*", 
          RowBox[{"(", 
           RowBox[{"l", " ", "+", " ", "1"}], ")"}]}], ")"}], "/", "2"}], 
       ")"}], " ", "-", " ", "0.375"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Analytic", " ", "WS", " ", "including", " ", "spin"}], "-", 
     "orbit"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"analyticWSwithSO", " ", "=", " ", 
     RowBox[{"centralWS", " ", "-", " ", 
      RowBox[{
      "VLS", "*", "invRVec", " ", "*", "spinCouplingTerm", "*", 
       "dcentralDR"}]}]}], ";"}], "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9717818397460384`*^9, 3.971781883586317*^9}, {
  3.9717821648444386`*^9, 3.9717822296559258`*^9}, {3.9717822608103065`*^9, 
  3.971782267197439*^9}, {3.971782299313259*^9, 3.971782352619713*^9}, {
