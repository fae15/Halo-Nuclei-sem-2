Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"do", " ", "a", " ", "safe", " ", "logarithm"}], ",", " ", 
    RowBox[{
    "copes", " ", "if", " ", "the", " ", "logarithm", " ", "is", " ", 
     "undefined", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
       "aka", " ", "if", " ", "our", " ", "fit", " ", "sucked", " ", "and", " ",
         "there", " ", "are", " ", "regions", " ", "of", " ", "positive", " ",
         "potential"}], ",", " ", 
       RowBox[{
       "this", " ", "was", " ", "kicking", " ", "my", " ", "ass", " ", 
        "earlier", " ", "and", " ", "i", " ", 
        RowBox[{"couldn", "'"}], "t", " ", "see", " ", "any", " ", 
        "graphs"}]}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"safeLog", "[", "list_", "]"}], " ", ":=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"#", " ", "<", " ", "0"}], ",", " ", 
          RowBox[{"Log", "[", 
           RowBox[{"-", "#"}], "]"}], ",", " ", "Indeterminate"}], "]"}], " ",
         "&"}], ",", " ", "list"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p1", " ", "=", " ", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"rVals", ",", " ", "analyticWS"}], "}"}], "]"}], ",", " ", 
         "\n", "    ", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"rVals", ",", " ", "fittedTwoBasic"}], "}"}], "]"}]}], 
        "}"}], ",", "\n", "   ", 
       RowBox[{"PlotLegends", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Analytic WS (no SO)\>\"", ",", 
          " ", "\"\<2-Gauss Fit\>\""}], "}"}]}], ",", "\n", "   ", 
       RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", " ", 
       RowBox[{"AxesLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<r (fm)\>\"", ",", " ", "\"\<V(r) (MeV)\>\""}], 
         "}"}]}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"p2", " ", "=", " ", 
