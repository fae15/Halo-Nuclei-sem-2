f19de735dcde"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"betas2", " ", "=", " ", 
   RowBox[{"generateBetas", "[", "2", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"betas12", " ", "=", " ", 
    RowBox[{"generateBetas", "[", "12", "]"}]}], ";"}], "\[IndentingNewLine]",
   "\n", 
  RowBox[{"(*", 
   RowBox[{
   "add", " ", "the", " ", "design", " ", "matrix", " ", "which", " ", 
    "represents", " ", "the", " ", "least", " ", "squares", " ", "problem", " ", 
    RowBox[{"(", 
     RowBox[{"without", " ", "any", " ", "ridge", " ", "regression", " ", 
      RowBox[{"yet", "!"}]}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"designMatrix", "[", 
     RowBox[{"rList_", ",", " ", "betas_"}], "]"}], " ", ":=", " ", "\n", 
    "  ", 
    RowBox[{"Transpose", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"betas", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "*", 
         RowBox[{"rList", "^", "2"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "betas", "]"}]}], "}"}]}], "]"}], "]"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "do", " ", "the", " ", "curvefit", " ", "using", " ", "ridge", " ", 
     "regression"}], ",", " ", 
    RowBox[{"adding", " ", "column", " ", "scaling"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ridgeSolve", "[", 
     RowBox[{"designMatrix_", ",", "targetVector_", ",", 
      RowBox[{"lambda_", ":", "1.*^-6"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"X", "=", "designMatrix"}], ",", 
        RowBox[{"y", "=", "targetVector"}], ",", "numSamples", ",", 
        "numFeatures", ",", "columnNorms", ",", "Xscaled", ",", "identityMat",
         ",", "normalMatrix", ",", "rhs", ",", "scaledCoeffs", ",", 
        "coeffs"}], "}"}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"renaming", " ", "things", " ", "so", " ", "i", " ", 
         RowBox[{"don", "'"}], "t", " ", "have", " ", "to", " ", "type", " ", 
         "all", " ", "these", " ", "words", " ", "every", " ", "time", "\[IndentingNewLine]",
          "designMatrix", " ", 
         RowBox[{"(", "x", ")"}], " ", "is", " ", "our", " ", "matrix", " ", 
         "of", " ", "gaussians", " ", "which", " ", "we", " ", "wanna", " ", 
         "converge", " ", "towards", " ", "our", " ", "WS", "\[IndentingNewLine]",
          "targetVector", " ", 
         RowBox[{"(", "y", ")"}], " ", "is", " ", "what", " ", "we", " ", 
         "wanna", " ", "fit", " ", "to", " ", 
         RowBox[{"(", 
          RowBox[{
          "in", " ", "this", " ", "case", " ", "our", " ", "analytic", " ", 
           "WS"}], ")"}], "\[IndentingNewLine]", "lambda", " ", "is", " ", 
         "related", " ", "to", " ", "the", " ", "penalty", " ", "term", " ", 
         "for", " ", "having", " ", "weirdly", " ", "large", " ", 
         "coefficients"}], " ", "-", " ", 
        RowBox[{
        "i", " ", "picked", " ", "small", " ", "numbers", " ", "for", " ", 
         "this", " ", "and", " ", "it", " ", "seemed", " ", "to", " ", "work",
          " ", "ok", "\[IndentingNewLine]", "numSamples", " ", "is", " ", 
         "the", " ", "number", " ", "of", " ", "r", " ", "values", "\[IndentingNewLine]",
          "numFeatures", " ", "is", " ", "the", " ", "numer", " ", "of", " ", 
         "parameters", " ", "to", " ", "be", " ", "curve", " ", "fitted"}]}], 
       "\[IndentingNewLine]", "*)"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"numSamples", ",", "numFeatures"}], "}"}], "=", 
        RowBox[{"Dimensions", "[", "X", "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"do", " ", "column", " ", "scaling"}], " ", "-", " ", 
         RowBox[{
         "find", " ", "norm", " ", "of", " ", "each", " ", "column"}]}], 
        "*)"}], 
       RowBox[{"columnNorms", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Norm", "[", 
              RowBox[{"X", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "j"}], "]"}], "]"}], "]"}], "==", "0"}], ",",
             "1.", ",", 
            RowBox[{"Norm", "[", 
             RowBox[{"X", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "j"}], "]"}], "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "numFeatures"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "normalise", " ", "columns", " ", "so", " ", "each", " ", "has", " ",
           "norm"}], "=", "1"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"Xscaled", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", "X", "]"}], "/", "columnNorms"}], "]"}]}],
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "do", " ", "the", " ", "curvefit", " ", "with", " ", "the", " ", 
         "ridge", " ", "regression", " ", "term", " ", "added"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"identityMat", "=", 
        RowBox[{"IdentityMatrix", "[", "numFeatures", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"normalMatrix", "=", 
        RowBox[{
         RowBox[{"Transpose", "[", "Xscaled", "]"}], ".", "Xscaled"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rhs", "=", 
        RowBox[{
         RowBox[{"Transpose", "[", "Xscaled", "]"}], ".", "y"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "mathematica", " ", "LinearSolve", " ", "solves", " ", "linear", " ", 
         "system", " ", "of", " ", "equations", " ", "generated", " ", "by", " ",
          "our", " ", "regression", " ", "equation"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"scaledCoeffs", "=", 
        RowBox[{"LinearSolve", "[", 
         RowBox[{
          RowBox[{"normalMatrix", "+", 
           RowBox[{"lambda", "*", "identityMat"}]}], ",", "rhs"}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "divide", " ", "coefficients", " ", "by", " ", "the", " ", "norm", " ",
          "of", " ", "each", " ", "column", " ", "to", " ", "undo", " ", 
         "the", " ", "column", " ", "scaling", " ", "we", " ", "did", " ", 
         "earlier", " ", "and", " ", "get", " ", "the", " ", "true", " ", 
         RowBox[{"params", "!"}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"coeffs", "=", 
        RowBox[{"scaledCoeffs", "/", "columnNorms"}]}], ";", 
       "\[IndentingNewLine]", "coeffs"}]}], "\[IndentingNewLine]", "]"}]}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "do", " ", "the", " ", "curve", " ", "fit", " ", "to", " ", "the", " ", 
     "woods"}], "-", 
    RowBox[{
    "saxon", " ", "without", " ", "any", " ", "spin", " ", "orbit", " ", 
     "term", " ", "added"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"design2", " ", "=", " ", 
   RowBox[{"designMatrix", "[", 
    RowBox[{"rVals", ",", " ", "betas2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"design12", " ", "=", " ", 
   RowBox[{"designMatrix", "[", 
    RowBox[{"rVals", ",", " ", "betas12"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bvec", " ", "=", " ", 
    RowBox[{"analyticWS", " ", "/", " ", "V0"}]}], 
   RowBox[{"(*", 
    RowBox[{
    "just", " ", "divided", " ", "by", " ", "V0", " ", "for", " ", "clarity", 
     " ", "so", " ", "i", " ", 
     RowBox[{"don", "'"}], "t", " ", "get", " ", "confused", " ", "about", " ",
      "whether", " ", "the", " ", "coefficients", " ", "have", " ", "been", " ",
      "scaled", " ", "by", " ", "V0", " ", "or", " ", "not", " ", "lol"}], 
    "*)"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"coeffs2", " ", "=", " ", 
   RowBox[{"ridgeSolve", "[", 
    RowBox[{"design2", ",", " ", "bvec", ",", " ", "1.*^-8"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"coeffs12", " ", "=", " ", 
   RowBox[{"ridgeSolve", "[", 
    RowBox[{"design12", ",", " ", "bvec", ",", " ", "1.*^-6"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "coeffs2", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", "coeffs12", "]"}], ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "put", " ", "them", " ", "V0s", " ", "back", " ", "in", " ", "to", " ", 
    "get", " ", "the", " ", "gaussians", " ", 
    RowBox[{"yippee", "!"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fittedTwoBasic", " ", "=", " ", 
   RowBox[{"V0", "*", 
    RowBox[{"(", 
     RowBox[{"design2", " ", ".", " ", "coeffs2"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"fittedTwelveBasic", " ", "=", " ", 
   RowBox[{"V0", "*", 
    RowBox[{"(", 
     RowBox[{"design12", " ", ".", " ", "coeffs12"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
