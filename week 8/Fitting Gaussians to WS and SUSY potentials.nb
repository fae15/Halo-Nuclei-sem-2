Cell["\<\
now compute derivatives of the gaussian fits in order to obtain a fit to the \
modified woods-saxon with the spin-orbit added\
\>", "Text",
 CellChangeTimes->{{3.9717856591142597`*^9, 
  3.971785692721689*^9}},ExpressionUUID->"08da5475-4a5c-6f46-8399-\
3046ffcc2670"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "derivative", " ", "of", " ", "all", " ", "the", " ", "terms", " ", "in", " ",
     "the", " ", "linear", " ", "regression", " ", "design", " ", "matrix", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"i", ".", "e", ".", " ", "the"}], " ", "matrix", " ", "of", " ",
       "gaussians"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"designDeriv", "[", 
      RowBox[{"rList_", ",", " ", "betas_"}], "]"}], " ", ":=", " ", "\n", 
     "  ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"betas", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "*", "rList", "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"betas", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "*", 
           RowBox[{"rList", "^", "2"}]}], "]"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", 
          RowBox[{"Length", "[", "betas", "]"}]}], "}"}]}], "]"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dVdr2", " ", "=", " ", 
     RowBox[{"V0", "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"designDeriv", "[", 
         RowBox[{"rVals", ",", " ", "betas2"}], "]"}], " ", ".", " ", 
        "coeffs2"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dVdr12", " ", "=", " ", 
     RowBox[{"V0", "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"designDeriv", "[", 
         RowBox[{"rVals", ",", " ", "betas12"}], "]"}], " ", ".", " ", 
        "coeffs12"}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dVdrOverR2", " ", "=", " ", 
     RowBox[{"dVdr2", "*", "invRVec"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dVdrOverR12", " ", "=", " ", 
     RowBox[{"dVdr12", "*", "invRVec"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"spinTermTwo", " ", "=", " ", 
     RowBox[{"VLS", "*", "spinCouplingTerm", "*", "dVdrOverR2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"spinTermTwelve", " ", "=", " ", 
     RowBox[{"VLS", "*", "spinCouplingTerm", "*", "dVdrOverR12"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"correctedTwo", " ", "=", " ", 
     RowBox[{"fittedTwoBasic", " ", "-", " ", "spinTermTwo"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"correctedTwelve", " ", "=", " ", 
     RowBox[{"fittedTwelveBasic", " ", "-", " ", "spinTermTwelve"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "print", " ", "the", " ", "maximum", " ", "difference", " ", "over", " ",
       "all", " ", "r", " ", "between", " ", "our", " ", "fit", " ", "and", " ",
       "the", " ", "real"}], "-", 
     RowBox[{
     "woods", " ", "saxon", " ", "potential", "\[IndentingNewLine]", "am", " ",
       "using", " ", "this", " ", "now", " ", "to", " ", "characterise", " ", 
      "the", " ", "goodness", " ", "of", " ", "the", " ", "fit", " ", "we", " ",
       "can", " ", "do", " ", "something", " ", "more", " ", "rigorous", " ", 
      "later"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Max difference analytic WS vs corrected 2-Gauss: \>\"", ",",
        " ", "\n", "  ", 
       RowBox[{"Max", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"analyticWSwithSO", " ", "-", " ", "correctedTwo"}], "]"}], 
        "]"}]}], "]"}], ";", "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Max difference analytic WS vs corrected 12-Gauss: \>\"", ",",
        " ", "\n", "  ", 
       RowBox[{"Max", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"analyticWSwithSO", " ", "-", " ", "correctedTwelve"}], 
         "]"}], "]"}]}], "]"}], ";"}], "*)"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.971785711042635*^9, 3.971785749615549*^9}, {
   3.9717857898992424`*^9, 3.971785829576193*^9}, 3.9717858796415577`*^9, {
   3.971787934834713*^9, 3.9717879516824665`*^9}},
 CellLabel->
  "In[215]:=",ExpressionUUID->"e1ad53de-a532-8145-a0a6-4b2340f43ba3"],

Cell["\<\
plot everything!
NOTE:
