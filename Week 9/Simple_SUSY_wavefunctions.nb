(* Beginning of Notebook Content *)
Notebook[{
Cell[TextData[{
 "We want to use the  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["l", "TI"], "+", "1"}], TraditionalForm], "errors" -> {}, 
     "input" -> "l+1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "21644133-2787-da4a-bc59-0845de6bfb88"],
 " radial wavefunctions to get our basis states for our SUSY calculation, \
however up until this point the wavefunctions were derived for the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["l", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "l=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f27ea0d-b58f-6b43-b5d6-75493b47ca2a"],
 " case only, we want to get the general case with the additional r term for \
our matrix elements here, the three body calculations can then follow from \
the work in the previous notebook (see Week 4 folder)."
}], "Text",
 CellChangeTimes->{{3.9857546354357147`*^9, 
  3.985754811236107*^9}},ExpressionUUID->"916469d4-47ed-c140-9876-\
cc511e2f28b8"],

Cell[TextData[{
 "We have basis states of  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["i", "TI"], "\[RightAngleBracket]", "\[LongEqual]", 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{
            StyleBox["l", "TI"], "+", "1"}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "|i\\rangle = \
\\Phi_{i}^{(l)}(r)=N_{i}r^{l+1}e^{-\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}\
", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "41df84a1-dc21-944e-ae7f-26cb0bd645cd"],
 ", and assume a separable form for the wavefunction of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SubsuperscriptBox[
          StyleBox["Y", "TI"], 
          StyleBox["l", "TI"], 
          StyleBox["m", "TI"]], 
         RowBox[{"(", 
           RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\Phi_{i}^{(l)}(r)Y_{l}^{m}(\\theta,\\phi)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4251ed3f-b1ae-ab4c-9377-154376625332"],
 ".\nThe normalisation is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             StyleBox["i", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubsuperscriptBox["\[CapitalPhi]", 
               StyleBox["i", "TI"], 
               RowBox[{"(", 
                 StyleBox["l", "TI"], ")"}]], "(", 
              StyleBox["r", "TI"], ")"}], ")"}], "2"], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\langle \
i|i\\rangle=\\int_{0}^{\\infty}\\left(\\Phi_{i}^{(l)}(r)\\right)^{2}r^{2}dr=\
1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf549b4b-3497-194f-b3b4-dcdf18320f9a"]
}], "Text",
 CellChangeTimes->{{3.985754804409193*^9, 3.98575481400317*^9}, {
   3.9857551420156994`*^9, 3.9857551907202663`*^9}, {3.985755236721958*^9, 
   3.9857552454132195`*^9}, 
   3.9857552899126167`*^9},ExpressionUUID->"b155469b-484c-9643-a626-\
c25f3e0fb86e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GaussianWavefunc", "[", 
   RowBox[{"r_", ",", " ", "l_", ",", " ", "\[Alpha]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"r", "^", 
    RowBox[{"(", 
     RowBox[{"l", "+", "1"}], ")"}]}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["r", "2"]}], "/", 
     SuperscriptBox["\[Alpha]", "2"]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"GaussianWavefunc", "[", 
     RowBox[{"r", ",", "l", ",", " ", "\[Alpha]"}], "]"}], " ", 
    RowBox[{"GaussianWavefunc", "[", 
     RowBox[{"r", ",", " ", "l", ",", " ", "\[Alpha]"}], "]"}], 
    SuperscriptBox["r", "2"]}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"\[Alpha]", ">", "0"}], "\[And]", 
     RowBox[{"l", ">=", "0"}]}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9857553724496784`*^9, 3.9857554331634007`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"9bb094e9-91f9-3f46-bb36-9121d1daab2c"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["2", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["7", "2"]}], "-", "l"}]], " ", 
  SuperscriptBox["\[Alpha]", 
   RowBox[{"5", "+", 
    RowBox[{"2", " ", "l"}]}]], " ", 
  RowBox[{"Gamma", "[", 
   RowBox[{
    FractionBox["5", "2"], "+", "l"}], "]"}]}]], "Output",
 CellChangeTimes->{{3.985755413661045*^9, 3.9857554343517513`*^9}},
 CellLabel->"Out[4]=",ExpressionUUID->"aa9dba75-1c63-934c-8978-90a6ee56178e"]
}, Open  ]],

Cell[TextData[{
 "So our normalisation is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             SuperscriptBox["2", 
              RowBox[{
                FractionBox["7", "2"], "+", 
                StyleBox["l", "TI"]}]], 
             RowBox[{
               SuperscriptBox["\[Alpha]", 
                RowBox[{"5", "+", "2", 
                  StyleBox["l", "TI"]}]], "\[CapitalGamma]", 
               RowBox[{"(", 
                 RowBox[{
                   FractionBox["5", "2"], "+", 
                   StyleBox["l", "TI"]}], ")"}]}]], ")"}], 
          FractionBox["1", "2"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "N_{i}=\\left(\\frac{2^{\\frac{7}{2}+l}}{\\alpha^{5+2l}\\Gamma(\\frac{5}{\
2}+l)}\\right)^{\\frac{1}{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "486fb445-0348-5842-bb3b-efd229187181"]
}], "Text",
 CellChangeTimes->{{3.985755443850706*^9, 
  3.985755451238537*^9}},ExpressionUUID->"0cfac121-690b-d448-aea5-\
cd624bfb06fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"WaveFuncNormalisation", "[", 
   RowBox[{"\[Alpha]_", ",", "L_"}], "]"}], ":=", 
  SuperscriptBox[
   RowBox[{"(", 
    FractionBox[
     SuperscriptBox["2", 
      RowBox[{
       FractionBox["7", "2"], "+", "L"}]], 
     RowBox[{
      SuperscriptBox["\[Alpha]", 
       RowBox[{"5", "+", 
        RowBox[{"2", "L"}]}]], 
      RowBox[{"Gamma", "[", 
       RowBox[{
        FractionBox["5", "2"], "+", "L"}], "]"}]}]], ")"}], 
   FractionBox["1", "2"]]}]], "Input",
 CellChangeTimes->{{3.985755621233238*^9, 3.985755673496666*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"ccce78a9-ef97-e646-9513-c5111698d3de"],

Cell[TextData[{
 "We now want the overlap matrix elements for this state, \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["j", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle \
i|j\\rangle=\\int_{0}^{\\infty}\\Phi_{i}^{(l)}(r)\\Phi_{j}^{(l)}(r)r^{2}dr", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cffd371d-10f7-7443-98fd-62d5c058be68"]
}], "Text",
 CellChangeTimes->{{3.985755677051695*^9, 
  3.98575571731336*^9}},ExpressionUUID->"a9ba36dc-693b-6940-93b9-\
8c8f1ff6a6b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"PowerExpand", "[", 
   RowBox[{
    RowBox[{"WaveFuncNormalisation", "[", 
     RowBox[{"\[Alpha]i", ",", "L"}], "]"}], 
    RowBox[{"WaveFuncNormalisation", "[", 
     RowBox[{"\[Alpha]j", ",", "L"}], "]"}], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"GaussianWavefunc", "[", 
        RowBox[{"r", ",", "L", ",", " ", "\[Alpha]i"}], "]"}], " ", 
       RowBox[{"GaussianWavefunc", "[", 
        RowBox[{"r", ",", " ", "L", ",", " ", "\[Alpha]j"}], "]"}], 
       SuperscriptBox["r", "2"]}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
      RowBox[{"Assumptions", "->", 
       RowBox[{
        RowBox[{"\[Alpha]", ">", "0"}], "\[And]", 
        RowBox[{"l", ">=", "0"}]}]}]}], "]"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.985755767727579*^9, 3.985755876855732*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"f30a49c7-9189-6642-9155-b7512b3bc64a"],

Cell[BoxData[
 TemplateBox[{
   RowBox[{
     SuperscriptBox["2", 
      RowBox[{
        FractionBox["5", "2"], "+", "L"}]], " ", 
     SuperscriptBox["\[Alpha]i", 
      RowBox[{
        RowBox[{"-", 
          FractionBox["5", "2"]}], "-", "L"}]], " ", 
     SuperscriptBox[
      RowBox[{"(", 
        RowBox[{
          FractionBox["1", 
           SuperscriptBox["\[Alpha]i", "2"]], "+", 
          FractionBox["1", 
           SuperscriptBox["\[Alpha]j", "2"]]}], ")"}], 
      RowBox[{
        RowBox[{"-", 
          FractionBox["5", "2"]}], "-", "L"}]], " ", 
     SuperscriptBox["\[Alpha]j", 
      RowBox[{
        RowBox[{"-", 
          FractionBox["5", "2"]}], "-", "L"}]]}], 
   RowBox[{
     RowBox[{
       RowBox[{"Re", "[", "L", "]"}], ">", 
       RowBox[{"-", 
         FractionBox["5", "2"]}]}], "&&", 
     RowBox[{
       RowBox[{"Re", "[", 
         RowBox[{
           FractionBox["1", 
            SuperscriptBox["\[Alpha]i", "2"]], "+", 
           FractionBox["1", 
            SuperscriptBox["\[Alpha]j", "2"]]}], "]"}], ">", "0"}]}]},
  "ConditionalExpression"]], "Output",
 CellChangeTimes->{{3.985755800904297*^9, 3.9857558244819202`*^9}, 
   3.985755854735029*^9, 3.985755889938961*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"88bf2161-63b0-d840-8e30-67defe8dbc7b"]
}, Open  ]],

Cell[TextData[{
 "Hence ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             RowBox[{"2", 
               SubscriptBox["\[Alpha]", 
                StyleBox["i", "TI"]], 
               SubscriptBox["\[Alpha]", 
                StyleBox["j", "TI"]]}], 
             RowBox[{
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["i", "TI"], "2"], "+", 
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["j", "TI"], "2"]}]], ")"}], 
          RowBox[{
            FractionBox["5", "2"], "+", 
            StyleBox["l", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\langle \
i|j\\rangle=\\left(\\frac{2\\alpha_{i}\\alpha_{j}}{\\alpha_{i}^{2}+\\alpha_{j}\
^{2}}\\right)^{\\frac{5}{2}+l}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c2a20868-77aa-a245-861b-0a3657872202"],
 ".\n\nOur potential is of the form ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["V", "TI"], "0"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "V_{0}e^{-\\beta r^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b99f127b-a41a-0540-8e79-9045d0c60b50"],
 ", so gives matrix elems of the form\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             OverscriptBox[
              StyleBox["V", "TI"], "^"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["j", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\langle i|\\hat{V}|j\\rangle=\\int_{0}^{\\infty}\\Phi_{i}^{(l)}(r)e^{-\
\\beta r^{2}}\\Phi_{j}^{(l)}(r)r^{2}dr=O_{ij}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7bd6f89e-7b86-0f42-9741-970c0dc77e19"]
}], "Text",
 CellChangeTimes->{{3.98575590112521*^9, 3.985755913319847*^9}, {
  3.985756105309065*^9, 
  3.985756142417696*^9}},ExpressionUUID->"a75a9271-7989-2b44-9690-\
2715c86efc4b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GaussianPotential", "[", 
   RowBox[{"r_", ",", "\[Beta]_", ",", "V0_"}], "]"}], ":=", 
  RowBox[{"V0", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[Beta]"}], " ", 
     SuperscriptBox["r", "2"]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"FullSimplify", "[", 
  RowBox[{"PowerExpand", "[", 
   RowBox[{
    RowBox[{"WaveFuncNormalisation", "[", 
     RowBox[{"\[Alpha]i", ",", "L"}], "]"}], 
    RowBox[{"WaveFuncNormalisation", "[", 
     RowBox[{"\[Alpha]j", ",", "L"}], "]"}], 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"GaussianWavefunc", "[", 
        RowBox[{"r", ",", "L", ",", " ", "\[Alpha]i"}], "]"}], 
       RowBox[{"GaussianPotential", "[", 
        RowBox[{"r", ",", "\[Beta]", ",", "V0"}], "]"}], " ", 
       RowBox[{"GaussianWavefunc", "[", 
        RowBox[{"r", ",", " ", "L", ",", " ", "\[Alpha]j"}], "]"}], 
       SuperscriptBox["r", "2"]}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
      RowBox[{"Assumptions", "->", 
       RowBox[{
        RowBox[{"\[Alpha]", ">", "0"}], "\[And]", 
        RowBox[{"l", ">=", "0"}], "\[And]", 
        RowBox[{"\[Beta]", ">", "0"}]}]}]}], "]"}]}], "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.98575618954303*^9, 3.985756254906456*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"abfe4aff-63e4-fb40-ba9f-96ac5a0a6975"],

Cell[BoxData[
 TemplateBox[{
   RowBox[{
     SuperscriptBox["2", 
      RowBox[{
        FractionBox["5", "2"], "+", "L"}]], " ", "V0", " ", 
     SuperscriptBox["\[Alpha]i", 
      RowBox[{
        RowBox[{"-", 
          FractionBox["5", "2"]}], "-", "L"}]], " ", 
     SuperscriptBox["\[Alpha]j", 
      RowBox[{
        RowBox[{"-", 
          FractionBox["5", "2"]}], "-", "L"}]], " ", 
     SuperscriptBox[
      RowBox[{"(", 
        RowBox[{
          FractionBox["1", 
           SuperscriptBox["\[Alpha]i", "2"]], "+", 
          FractionBox["1", 
           SuperscriptBox["\[Alpha]j", "2"]], "+", "\[Beta]"}], ")"}], 
      RowBox[{
        RowBox[{"-", 
          FractionBox["5", "2"]}], "-", "L"}]]}], 
   RowBox[{
     RowBox[{
       RowBox[{"Re", "[", "L", "]"}], ">", 
       RowBox[{"-", 
         FractionBox["5", "2"]}]}], "&&", 
     RowBox[{
       RowBox[{"\[Beta]", "+", 
         RowBox[{"Re", "[", 
           RowBox[{
             FractionBox["1", 
              SuperscriptBox["\[Alpha]i", "2"]], "+", 
             FractionBox["1", 
              SuperscriptBox["\[Alpha]j", "2"]]}], "]"}]}], ">", "0"}]}]},
  "ConditionalExpression"]], "Output",
 CellChangeTimes->{3.9857562839004135`*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"14d6671a-ce98-b843-804b-e348dd88fd3e"]
}, Open  ]],

Cell[TextData[{
 "Hence ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             OverscriptBox[
              StyleBox["V", "TI"], "^"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["V", "TI"], "0"], 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             RowBox[{"2", 
               SubscriptBox["\[Alpha]", 
                StyleBox["i", "TI"]], 
               SubscriptBox["\[Alpha]", 
                StyleBox["j", "TI"]]}], 
             RowBox[{
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["i", "TI"], "2"], "+", 
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["j", "TI"], "2"], "+", 
               SubsuperscriptBox["\[Beta]\[Alpha]", 
                StyleBox["i", "TI"], "2"], 
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["j", "TI"], "2"]}]], ")"}], 
          RowBox[{
            FractionBox["5", "2"], "+", 
            StyleBox["l", "TI"]}]], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], 
          RowBox[{"(", 
            RowBox[{
              StyleBox["c", "TI"], 
              StyleBox["n", "TI"]}], ")"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\langle \
i|\\hat{V}|j\\rangle=V_{0}\\left(\\frac{2\\alpha_{i}\\alpha_{j}}{\\alpha_{i}^{\
2}+\\alpha_{j}^{2}+\\beta\\alpha_{i}^{2}\\alpha_{j}^{2}}\\right)^{\\frac{5}{2}\
+l}=V_{ij}^{(cn)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc087766-69e5-5c47-b21c-5860bdd22a91"],
 ".\nThe potential matrix has the form (after some rearranging)\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             OverscriptBox[
              StyleBox["T", "TI"], "^"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"8", 
            SuperscriptBox["\[Pi]", "2"], "\[Mu]"}]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              StyleBox["d", "TI"], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]], 
             RowBox[{"[", 
               RowBox[{
                 StyleBox["r", "TI"], 
                 SubsuperscriptBox["\[CapitalPhi]", 
                  StyleBox["i", "TI"], 
                  RowBox[{"(", 
                    StyleBox["l", "TI"], ")"}]], 
                 RowBox[{"(", 
                   StyleBox["r", "TI"], ")"}]}], "]"}]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              StyleBox["d", "TI"], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]], 
             RowBox[{"[", 
               RowBox[{
                 StyleBox["r", "TI"], 
                 SubsuperscriptBox["\[CapitalPhi]", 
                  StyleBox["j", "TI"], 
                  RowBox[{"(", 
                    StyleBox["l", "TI"], ")"}]], 
                 RowBox[{"(", 
                   StyleBox["r", "TI"], ")"}]}], "]"}]}], ")"}], "+", 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         FractionBox[
          RowBox[{
            StyleBox["l", "TI"], "(", 
            RowBox[{
              StyleBox["l", "TI"], "+", "1"}], ")"}], 
          SuperscriptBox[
           StyleBox["r", "TI"], "2"]], 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["j", "TI"], 
          RowBox[{"(", 
            StyleBox["l", "TI"], ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle \
i|\\hat{T}|j\\rangle=\\frac{h^{2}}{8\\pi^{2}\\mu}\\int_{0}^{\\infty}\\left(\\\
frac{d}{dr}\\left \
[r\\Phi_{i}^{(l)}(r)\\right]\\right)\\left(\\frac{d}{dr}\\left[ \
r\\Phi_{j}^{(l)}(r)\\right]\\right) \
+\\Phi_{i}^{(l)}(r)\\frac{l(l+1)}{r^{2}}\\Phi_{j}^{(l)}(r)r^{2}dr", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3da96927-dba7-e549-9cb6-49474d5474a7"]
}], "Text",
 CellChangeTimes->{{3.9857562621732616`*^9, 3.9857562797289906`*^9}, {
  3.9857563760429344`*^9, 3.9857564188987656`*^9}, {3.9857564580333214`*^9, 
