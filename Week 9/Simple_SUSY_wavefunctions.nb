Cell[TextData[{
 "Do not seem to get simple cancellation as in the previous case without the \
+1 added to the L. Matrix elem written as \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               StyleBox["h", "TI"], 
               StyleBox["b", "TI"], 
               StyleBox["a", "TI"], 
               StyleBox["r", "TI"]}], ")"}], "2"], 
          RowBox[{"2", "\[Mu]"}]], 
         FractionBox[
          SuperscriptBox["2", 
           RowBox[{
             FractionBox["7", "2"], "+", 
             StyleBox["l", "TI"]}]], 
          RowBox[{"3", "+", "2", 
            StyleBox["l", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "T_{ij}=\\frac{(hbar)^{2}}{2\\mu}\\frac{2^{\\frac{7}{2}+l}}{3+2l}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c691540-d05a-ab47-803f-ccb3d36e9eba"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              RowBox[{
                StyleBox["l", "TI"], "(", 
                RowBox[{
                  StyleBox["l", "TI"], "+", "1"}], ")"}], 
              RowBox[{
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["j", "TI"]]}]], 
             SuperscriptBox[
              RowBox[{"(", 
                FractionBox[
                 RowBox[{
                   SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]], 
                   SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]}], 
                 RowBox[{
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"], "+", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"], "2"]}]], ")"}], 
              RowBox[{
                FractionBox["3", "2"], "+", 
                StyleBox["l", "TI"]}]], "-", 
             FractionBox[
              SuperscriptBox[
               RowBox[{"(", 
                 RowBox[{
                   SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]], 
                   SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]}], ")"}], 
               RowBox[{
                 FractionBox["1", "2"], "+", 
                 StyleBox["l", "TI"]}]], 
              SuperscriptBox[
               RowBox[{"(", 
                 RowBox[{
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"], "+", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"], "2"]}], ")"}], 
               RowBox[{
                 FractionBox["7", "2"], "+", 
                 StyleBox["l", "TI"]}]]], 
             RowBox[{"(", 
               RowBox[{
                 RowBox[{"(", 
                   RowBox[{"1", "+", 
                    StyleBox["l", "TI"]}], ")"}], 
                 RowBox[{"(", 
                   RowBox[{"2", "+", 
                    StyleBox["l", "TI"]}], ")"}], 
                 RowBox[{"(", 
                   RowBox[{
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "4"], "+", 
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"], "4"]}]}]}], ")"}], "-", 
             RowBox[{"(", 
               RowBox[{"11", "+", "2", 
                 StyleBox["l", "TI"], 
                 RowBox[{"(", 
                   RowBox[{"5", "+", 
                    StyleBox["l", "TI"]}], ")"}]}], ")"}], 
             SubsuperscriptBox["\[Alpha]", 
              StyleBox["i", "TI"], "2"], 
             SubsuperscriptBox["\[Alpha]", 
              StyleBox["j", "TI"], "2"]}], ")"}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\left(\\frac{l(l+1)}{\\alpha_{i}\\alpha_{j}}\\left(\\frac{\\alpha_{i}\\\
alpha_{j}}{\\alpha_{i}^{2}+\\alpha_{j}^{2}}\\right)^{\\frac{3}{2}+l}-\\frac{\\\
left(\\alpha_{i}\\alpha_{j}\\right)^{\\frac{1}{2}+l}}{\\left(\\alpha_{i}^{2}+\
\\alpha_{j}^{2}\\right)^{\\frac{7}{2}+l}}\\left((1+l)(2+l)(\\alpha_{i}^{4}+\\\
alpha_{j}^{4}\\right)-(11+2l(5+l))\\alpha_{i}^{2}\\alpha_{j}^{2} \\right) \
\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "38cac048-59f6-b443-be31-eaf3bda0d45a"],
 ". (Second last bracket  is behaving weirdly)"
}], "Text",
