Cell[TextData[{
 "For the actual SUSY potential we are working with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", 
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], 
         RowBox[{"(", 
           RowBox[{"ln", 
             SubscriptBox[
              StyleBox["u", "TI"], "0"], 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "2\\frac{d^{2}}{dr^{2}}\\left(\\text{ln} u_{0}(r)\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "60bcec87-b251-e948-a179-f88b4db8973d"],
 " (neglecting factors of \[HBar] and m), which gives two terms,\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-2", 
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], 
         RowBox[{"(", 
           RowBox[{"ln", "(", 
             RowBox[{
               StyleBox["r", "TI"], 
               SubscriptBox[
                StyleBox["R", "TI"], "0"], 
               RowBox[{"(", 
                 StyleBox["r", "TI"], ")"}]}], ")"}], ")"}], "\[LongEqual]", 
         "-2", 
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], 
         RowBox[{"(", 
           RowBox[{"ln", 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}], "+", "ln", 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["R", "TI"], "0"], "(", 
                 StyleBox["r", "TI"], ")"}], ")"}]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "-2\\frac{d^{2}}{dr^{2}}\\left(\\text{ln}(rR_{0}(r))\\right)=-2\\frac{d^{\
2}}{dr^{2}}\\left(\\text{ln}(r)+\\text{ln}(R_{0}(r))\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "96cea400-ba32-2140-ad43-149f68194946"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         FractionBox["2", 
          SuperscriptBox[
           StyleBox["r", "TI"], "2"]], "-", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["d", "TI"], "2"], "(", 
            RowBox[{"ln", 
              SubscriptBox[
               StyleBox["R", "TI"], "0"], 
              RowBox[{"(", 
                StyleBox["r", "TI"], ")"}]}], ")"}], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "=\\frac{2}{r^{2}}-\\frac{d^{2}(\\text{ln}R_{0}(r))}{dr^{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bdff7983-ea07-6447-b1c6-33de059cbedf"],
 " .\nThe second term we handle with gaussians, the first we need to deal \
with directly, we do this by"
}], "Text",
 CellChangeTimes->{{3.9857673927287464`*^9, 3.985767431813711*^9}, {
   3.9857675303308887`*^9, 3.9857675600772934`*^9}, 3.985767673360386*^9, {
