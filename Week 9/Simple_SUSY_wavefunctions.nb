Cell[TextData[{
 "So for the supersymmetric term obtain a term similar to the potential one \
that\[CloseCurlyQuote]s been fit with gaussians, and a matric element of \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             FractionBox["1", 
              SuperscriptBox[
               StyleBox["r", "TI"], "2"]], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox["2", 
           RowBox[{
             FractionBox["9", "2"], "+", 
             StyleBox["l", "TI"]}]], 
          RowBox[{
            SubscriptBox["\[Alpha]", 
             StyleBox["i", "TI"]], 
            SubscriptBox["\[Alpha]", 
             StyleBox["j", "TI"]], 
            RowBox[{"(", 
              RowBox[{"3", "+", "2", 
                StyleBox["l", "TI"]}], ")"}]}]], 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             RowBox[{
               SubscriptBox["\[Alpha]", 
                StyleBox["i", "TI"]], 
               SubscriptBox["\[Alpha]", 
                StyleBox["j", "TI"]]}], 
             RowBox[{
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["i", "TI"], "2"], "+", 
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["j", "TI"], "2"]}]], ")"}], 
          RowBox[{
            FractionBox["3", "2"], "+", 
            StyleBox["l", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\langle \
i|\\frac{1}{r^{2}}|j\\rangle=\\frac{2^{\\frac{9}{2}+l}}{\\alpha_{i}\\alpha_{j}\
(3+2l)}\\left(\\frac{\\alpha_{i}\\alpha_{j}}{\\alpha_{i}^{2}+\\alpha_{j}^{2}}\
\\right)^{\\frac{3}{2}+l}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "758ae98b-0773-8d4b-9202-85c817a4fce7"]
}], "Text",
 CellChangeTimes->{{3.9857685235853386`*^9, 3.9857685603694744`*^9}, 
   3.985768669796753*^9},ExpressionUUID->"57806cf2-612b-724f-a2a7-\
d6238e1af1e6"],

Cell[TextData[{
 "The total Hamiltonian we are working with is \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             OverscriptBox[
              StyleBox["H", "TI"], "^"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             OverscriptBox[
              StyleBox["t", "TI"], "^"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "+", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             SuperscriptBox[
              OverscriptBox[
               StyleBox["V", "TI"], "^"], "(CN)"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "-", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             SuperscriptBox[
              OverscriptBox[
               StyleBox["V", "TI"], "^"], "(SUSY)"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle i|\\hat{H}|j\\rangle=\\langle i|\\hat{t}|j\\rangle+\\langle i|\
\\hat{V}^{\\text{(CN)}}|j\\rangle-\\langle \
i|\\hat{V}^{\\text{(SUSY)}}|j\\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2a06865e-bbd2-0d4c-82f5-43c414d6b16f"],
 ". The first term is derived above. For both potential terms we have either \
assumed a gaussian form for the core neutron interaction, or fit gaussians to \
the SUSY params, plus the 1/r^2 term. In theory we should just add one l to \
the wavefunctions so this should in theory work, now need to test this in \
python."
}], "Text",
 CellChangeTimes->{{3.9857584046057663`*^9, 3.9857584283372307`*^9}, {
  3.9857584602119846`*^9, 3.9857584602119846`*^9}, {3.9857585005944366`*^9, 
  3.9857585435919037`*^9}, {3.985758666920908*^9, 3.9857586924381065`*^9}, {
  3.985768676373354*^9, 
  3.985768682489622*^9}},ExpressionUUID->"f64b92c9-226c-fa49-884e-\
a22faf1a603e"]
},
