Notebook[{
Cell[TextData[{
 "The supersymmetric transform method makes a transform of the potential to \
remove a forbidden state  by taking\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["V", "TI"], "SUSY"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["V", "TI"], "CN"], "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", "\[Mu]"], 
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], "ln", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], 
             SubscriptBox["\[Psi]", 
              StyleBox["f", "TI"]], 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "V^{\\text{SUSY}}=V^{\\text{CN}}-\\frac{h^{2}}{4\\pi^{2}}\\frac{1}{\\mu}\
\\frac{d^{2}}{dr^{2}}\\ln\\left(r\\psi_{f}(r)\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2396988e-d8e2-7e4e-8e62-480ac7516153"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Psi]", 
          StyleBox["f", "TI"]], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\psi_{f}(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6d8676a0-d63e-5843-9f57-9a42d93c84fc"],
 " is the forbidden state wavefunction, which in the GEM is represented by \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Psi]", 
          StyleBox["f", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], ",  ", 
         SubscriptBox["\[CapitalPsi]", 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["i", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\psi_{f}(r)=\\sum_{i}c_{i}\\Phi_{i}(r),\\ \\ \
\\Psi_{i}(r)=N_{i}e^{-r^{2}/\\alpha_{i}^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9228cff4-ad9a-a045-a295-1ac63d45decc"],
 "\nThus the second derivative of the log is\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], "ln", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], 
             SubscriptBox["\[Psi]", 
              StyleBox["f", "TI"]]}], ")"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], 
         RowBox[{"(", 
           RowBox[{"ln", 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}], "+", "ln", 
             RowBox[{"(", 
               RowBox[{
                 UnderscriptBox["\[Sum]", 
                  StyleBox["i", "TI"], LimitsPositioning -> True], 
                 SubscriptBox[
                  StyleBox["c", "TI"], 
                  StyleBox["i", "TI"]], 
                 SubscriptBox["\[CapitalPhi]", 
                  StyleBox["i", "TI"]], 
                 RowBox[{"(", 
                   StyleBox["r", "TI"], ")"}]}], ")"}]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{d^{2}}{dr^{2}}\\ln(r\\psi_{f})=\\frac{d^{2}}{dr^{2}}\\left(\\ln(\
r)+\\ln\\left(\\sum_{i}c_{i}\\Phi_{i}(r)\\right)\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6eb9c126-8bcb-4d4a-9b12-78a9bd29ea9e"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", 
              StyleBox["r", "TI"]], "+", 
             FractionBox[
              RowBox[{
                SubsuperscriptBox["\[Psi]", 
                 StyleBox["f", "TI"], "\[Prime]"], "(", 
                StyleBox["r", "TI"], ")"}], 
              RowBox[{
                SubscriptBox["\[Psi]", 
                 StyleBox["f", "TI"]], "(", 
                StyleBox["r", "TI"], ")"}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "=\\frac{d}{dr}\\left(\\frac{1}{r}+\\frac{\\psi_{f}'(r)}{\\psi_{f}(r)}\\\
right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "66443d31-934d-2e4d-aa90-60fc3786fc6f"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox["\[Psi]", 
             StyleBox["f", "TI"]], 
            RowBox[{"(", 
              StyleBox["r", "TI"], ")"}], 
            SubsuperscriptBox["\[Psi]", 
             StyleBox["f", "TI"], "\[Prime]\[Prime]"], 
            RowBox[{"(", 
              StyleBox["r", "TI"], ")"}], "-", 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{
                 SubsuperscriptBox["\[Psi]", 
                  StyleBox["f", "TI"], "\[Prime]"], "(", 
                 StyleBox["r", "TI"], ")"}], ")"}], "2"]}], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["\[Psi]", 
                StyleBox["f", "TI"]], "(", 
               StyleBox["r", "TI"], ")"}], ")"}], "2"]], "-", 
         FractionBox["1", 
          SuperscriptBox[
           StyleBox["r", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "=\\frac{\\psi_{f}(r)\\psi_{f}''(r)-\\left(\\psi_{f}'(r)\\right)^{2}}{\\\
left(\\psi_{f}(r)\\right)^{2}}-\\frac{1}{r^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d02d467c-9bdc-984c-a98b-cd33905bf3df"],
 "\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Psi]", 
          StyleBox["f", "TI"], "\[Prime]"], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\psi_{f}'(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "66fe6c6d-e01b-384e-97dc-b9a89895e48b"],
 " is the derivative of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Psi]", 
          StyleBox["f", "TI"]], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\psi_{f}(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4438757a-6148-a244-b021-4e6034d6a4c3"],
 " with respect to r. These are represented by \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Psi]", 
          StyleBox["f", "TI"], "\[Prime]"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], "-", 
         FractionBox[
          RowBox[{"2", 
            SubscriptBox[
             StyleBox["c", "TI"], 
             StyleBox["i", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["i", "TI"]]}], 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["i", "TI"], "2"]], 
         StyleBox["r", "TI"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["i", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\psi_{f}'(r)=\\sum_{i}-\\frac{2c_{i}N_{i}}{\\alpha_{i}^{2}}re^{-r^{2}/\
\\alpha_{i}^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "554e7cb6-b273-f448-984e-5baef52a2d92"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Psi]", 
          StyleBox["f", "TI"], "\[Prime]\[Prime]"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         FractionBox[
          RowBox[{"2", 
            SubscriptBox[
             StyleBox["c", "TI"], 
             StyleBox["i", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["i", "TI"]]}], 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["i", "TI"], "2"]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              RowBox[{"2", 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}], 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "2"]], "-", "1"}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["i", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\psi_{f}''(r)=\\sum_{i}\\frac{2c_{i}N_{i}}{\\alpha_{i}^{2}}\\left(\\\
frac{2r^{2}}{\\alpha_{i}^{2}}-1\\right)e^{-r^{2}/\\alpha_{i}^{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3b3ac4fd-f53a-9a4d-bb02-245bf0abdf21"],
 "\nThe supersymmetric potential is written as \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["V", "TI"], "SUSY"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["V", "TI"], "CN"], "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", "\[Mu]"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              RowBox[{
                SubscriptBox["\[Psi]", 
                 StyleBox["f", "TI"]], 
                RowBox[{"(", 
                  StyleBox["r", "TI"], ")"}], 
                SubsuperscriptBox["\[Psi]", 
                 StyleBox["f", "TI"], "\[Prime]\[Prime]"], 
                RowBox[{"(", 
                  StyleBox["r", "TI"], ")"}], "-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   RowBox[{
                    SubsuperscriptBox["\[Psi]", 
                    StyleBox["f", "TI"], "\[Prime]"], "(", 
                    StyleBox["r", "TI"], ")"}], ")"}], "2"]}], 
              SuperscriptBox[
               RowBox[{"(", 
                 RowBox[{
                   SubscriptBox["\[Psi]", 
                    StyleBox["f", "TI"]], "(", 
                   StyleBox["r", "TI"], ")"}], ")"}], "2"]], "-", 
             FractionBox["1", 
              SuperscriptBox[
               StyleBox["r", "TI"], "2"]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "V^{\\text{SUSY}}=V^{\\text{CN}}-\\frac{h^{2}}{4\\pi^{2}}\\frac{1}{\\mu}\
\\left(\\frac{\\psi_{f}(r)\\psi_{f}''(r)-\\left(\\psi_{f}'(r)\\right)^{2}}{\\\
left(\\psi_{f}(r)\\right)^{2}}-\\frac{1}{r^{2}}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d234de45-3452-464e-a436-0aaf35c811ec"],
 "\nWe now want to plot this using the forbidden ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"1", 
          SubscriptBox[
           StyleBox["s", "TI"], 
           RowBox[{"1", "/", "2"}]]}], TraditionalForm], "errors" -> {}, 
      "input" -> "1s_{1/2}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "1080eb6f-2efb-bc4c-95fe-fb6be754dbb2"],
 "state in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Null]", "5"], "He"}], TraditionalForm], 
     "errors" -> {}, "input" -> "^{5}\\text{He}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "04e217a6-7263-5644-8fad-31b3aa8d60c5"],
 ". Taking ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["V", "TI"], "CN"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["V", "TI"], "0"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SuperscriptBox["\[Beta]", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "V^{\\text{CN}}=V_{0}e^{-r^{2}/\\beta^{2}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "69edb1b8-c120-9c43-8264-ac28f229013d"],
 " with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["V", "TI"], "0"], "\[LongEqual]", "-47.32", "MeV"}], 
       TraditionalForm], "errors" -> {}, "input" -> "V_{0}=-47.32\\text{MeV}",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c702b7de-e9ab-9f42-bd42-93bc20d881ed"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Beta]", "\[LongEqual]", "2.30", 
         SuperscriptBox["fm", "-2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta=2.30\\text{fm}^{-2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "875cd749-ff91-434c-8898-20117c419c21"],
 ". We use the results of the python calculation to get the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox[
         StyleBox["c", "TI"], 
         StyleBox["i", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
      "c_{i}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "2a55bbf2-6524-e942-9c45-5a134b860924"],
 " for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Psi]", 
          StyleBox["f", "TI"]], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\psi_{f}(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fe634575-23ec-7a42-987d-c28d9e49e210"]
}], "Text",
 CellChangeTimes->{{3.982735132616184*^9, 3.9827352038059883`*^9}, {
   3.9827352934876156`*^9, 3.982735322801239*^9}, {3.9827353758521442`*^9, 
   3.9827354097223682`*^9}, 3.9827355571121902`*^9, {3.9827356232779446`*^9, 
   3.9827356259950924`*^9}, {3.982735720598484*^9, 3.9827357723555374`*^9}, {
   3.9827358290544205`*^9, 3.982735830871956*^9}, {3.9827359583178196`*^9, 
   3.9827359898352165`*^9}, {3.9827360836135883`*^9, 
   3.9827361376731033`*^9}, {3.9827362834984894`*^9, 3.982736293446987*^9}, {
   3.982736327956196*^9, 3.9827364032913113`*^9}, {3.9827373709185963`*^9, 
   3.9827373773740807`*^9}},ExpressionUUID->"a2ef21a6-dda2-b748-b54f-\
34551c91aaa6"],

