     RowBox[{"10", "^", 
      RowBox[{"-", "07"}]}]}], ",", 
    RowBox[{
     RowBox[{"-", "6.28937678"}], "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "07"}]}]}], ",", 
    RowBox[{"1.97121551", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "06"}]}]}], ",", 
    RowBox[{
     RowBox[{"-", "5.26305283"}], "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "06"}]}]}], ",", " ", 
