Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GenerateRangParams", "[", 
    RowBox[{"numGaussians_Integer", ",", " ", 
     RowBox[{"r1_", ":", " ", "0.01"}], ",", " ", 
     RowBox[{"rmax_", ":", " ", "25"}]}], "]"}], " ", ":=", "  ", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rn", ",", " ", "a"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"r1", "/", "rmax"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"1", "-", "numGaussians"}], ")"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rn", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"r1", "*", 
          RowBox[{"a", "^", "i"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"i", ",", " ", "0", ",", " ", 
           RowBox[{"numGaussians", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}], ";",
       "\n", "  ", "rn"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"GenerateRangParams", "[", "20", "]"}]}], "Input",
 CellChangeTimes->{{3.9827364409203377`*^9, 3.982736518843872*^9}, {
