(* Beginning of Notebook Content *)
Notebook[{
Cell[TextData[{
 "This notebook seeks to derive the results needed to implement the SUSY \
method to remove bound states. We follow the work of Baye (1987) \
https://doi.org/10.1103/PhysRevLett.58.2738 and Amado et. al (1991) \
https://doi.org/10.1103/PhysRevC.43.2077 . As such we do not concern \
ourselves here with the specifics of super symmetry, but with the main result \
in transforming between \[OpenCurlyQuote]deep\[CloseCurlyQuote] and \
\[OpenCurlyQuote]shallow\[CloseCurlyQuote] nuclear potentials to remove \
unphysical bound states. We start with\n(1) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["H", "TI"], "1"], "\[LongEqual]", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["d", "TI"], "2"], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]], "+", 
         SubscriptBox[
          StyleBox["V", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "H_{1}=-\\frac{d^{2}}{dr^{2}}+V_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9009ca7f-171b-0e4e-b8ce-6f0a6173c02b"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       FractionBox[
        SuperscriptBox[
         StyleBox["h", "TI"], "2"], 
        RowBox[{"8", 
          SuperscriptBox["\[Pi]", "2"], "\[Mu]"}]], TraditionalForm], 
     "errors" -> {}, "input" -> "\\frac{h^{2}}{8\\pi^{2}\\mu}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "678d90b4-4113-f445-806e-aa561c733538"],
 " is normalised as 1 and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["V", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "V_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fe0ccf07-e3cd-bc45-884d-679c3252f7b9"],
 " contains both the interaction term and the centrifugal barrier. The \
eigenstates of (1) can be written as \n(2) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["H", "TI"], "1"], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "1", ")"}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["E", "TI"], 
          StyleBox["n", "TI"]], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "1", ")"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "H_{1}\\Psi_{n}^{(1)}=E_{n}\\Psi_{n}^{(1)}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8740bbb9-2972-3c47-8cd5-bfa38382b8f3"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], "\[Element]", 
         StyleBox["Z", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "n \\in \\mathfrak{Z}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a34dc9e3-6eaa-3245-82b6-093a5253b4ad"],
 " includes continuum states. We assume that the lowest energy state has \
energy ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["E", "TI"], "0"], "<", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "E_{0}<0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "54dce8a8-3c02-6a4a-9a78-ffdc149bc6c1"],
 ", and we write (1) in a factorised form as\n(3) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["H", "TI"], "1"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["A", "TI"], "1", "+"], 
         SubsuperscriptBox[
          StyleBox["A", "TI"], "1", "-"], "-", 
         SubscriptBox[
          StyleBox["E", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "H_{1}=A_{1}^{+}A_{1}^{-}-E_{0}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "388c7267-2048-9744-93d4-7076b3085fba"],
 ",\n(4) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["A", "TI"], "\[PlusMinus]"], "\[LongEqual]", 
         "\[PlusMinus]", 
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]], "+", 
         SuperscriptBox[
          StyleBox["W", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "A^{\\pm}=\\pm\\frac{d}{dr}+W^{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a3e059ce-0620-9e4a-942f-ea285f713321"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["W", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "W^{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ca3626d3-3377-0547-9225-fde4f0557fb3"],
 " is the superpotential given by \n(5) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["W", "TI"], "1"], "\[LongEqual]", 
         FractionBox["1", 
          SubsuperscriptBox["\[CapitalPsi]", "0", 
           RowBox[{"(", "1", ")"}]]], 
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            SubsuperscriptBox["\[CapitalPsi]", "0", 
             RowBox[{"(", "1", ")"}]]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "W_{1}=\\frac{1}{\\Psi_{0}^{(1)}}\\frac{d\\Psi_{0}^{(1)}}{dr}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4dfa8e8b-efec-7d40-9598-ab1b1858ea63"],
 ".\nThe supersymmetric partner Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox[
         StyleBox["H", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
      "H_{2}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "3024dac1-d55d-c048-943b-6795666ba0fb"],
 "is defined by \n(6) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["H", "TI"], "2"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["A", "TI"], "1", "-"], 
         SubsuperscriptBox[
          StyleBox["A", "TI"], "1", "+"], "-", 
         StyleBox["B", "TI"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["H", "TI"], "1"], "-", "2", 
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            SubscriptBox[
             StyleBox["W", "TI"], "1"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "H_{2}=A_{1}^{-}A_{1}^{+}-B=H_{1}-2\\frac{dW_{1}}{dr}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2a20734d-c620-ea40-9e7c-c02d0d63473a"],
 ".\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox[
         StyleBox["H", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
      "H_{2}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "91d56b6d-17e8-4047-b2a0-40e806ba5cbc"],
 "is isospectral to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["H", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "H_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2a2ec334-f1e4-5a46-a6e7-dac606a3a61b"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["H", "TI"], "2"], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "2", ")"}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["E", "TI"], 
          StyleBox["n", "TI"]], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "2", ")"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "H_{2}\\Psi_{n}^{(2)}=E_{n}\\Psi_{n}^{(2)}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5a9269a2-532e-d546-990e-e5addcca5bb2"],
 ", except for the state at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "E_{0}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0fefc467-94a2-bd44-8224-8aa03c7b4772"],
 ",  as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["A", "TI"], "1", "-"], 
         SubsuperscriptBox["\[CapitalPsi]", "0", 
          RowBox[{"(", "1", ")"}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "A_{1}^{-}\\Psi_{0}^{(1)}=0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "533eab53-2995-484c-a926-b7857e548915"],
 ". The eigenfunctions of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["H", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "H_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8dde5f0e-67b9-554d-a2da-b513babfddc0"],
 " are given in terms of those of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["H", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "H_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5df35c20-ac7b-b344-bcca-5b82e6bf1418"],
 " by \n(7) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "2", ")"}]], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["A", "TI"], "1", "-"], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "1", ")"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Psi_{n}^{(2)}=A_{1}^{-}\\Psi_{n}^{(1)}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "06310075-188a-c74e-8fdb-6c788118c516"],
 ",\nup to a normalisation factor. ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["H", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "H_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4c782407-4e78-a543-a72d-4beda2acfb53"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["H", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "H_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "795753dc-db33-424a-beec-37604817cee5"],
 " are not phase equivalent Hamiltonians, another step is needed to reach \
that point, see equations (11-18) in Amado (1991) for the derivation."
}], "Text",
 CellChangeTimes->{{3.9852462487419357`*^9, 3.985246253021282*^9}, {
   3.9852463011330757`*^9, 3.9852463110906086`*^9}, {3.985246345071314*^9, 
   3.9852464695698967`*^9}, {3.985246502769224*^9, 3.985246624824608*^9}, {
   3.985246764893257*^9, 3.985246774824301*^9}, {3.985246876758827*^9, 
   3.9852468987722073`*^9}, {3.9852469457575665`*^9, 
   3.9852469569169865`*^9}, {3.985247037963953*^9, 3.985247087578083*^9}, {
   3.9852473683280296`*^9, 3.9852474420419636`*^9}, {3.9852474784733143`*^9, 
   3.985247612064781*^9}, {3.98524765452816*^9, 3.985247661384081*^9}, {
   3.985247903462593*^9, 3.9852479632081566`*^9}, {3.985248283329233*^9, 
   3.9852482903941727`*^9}, {3.985248361875416*^9, 3.9852484158419037`*^9}, {
   3.9852484643180275`*^9, 3.985248506453825*^9}, {3.985248559940378*^9, 
   3.9852486557548103`*^9}, 3.9852486887237873`*^9, {3.9852487202155304`*^9, 
   3.9852487375873623`*^9}, {3.985249275371229*^9, 
   3.9852493534881973`*^9}},ExpressionUUID->"11b88470-1017-5945-a3ac-\
827f4a329711"],

Cell[TextData[{
 "Hence equations (6) and (7) tell us how to remove the unphysical bound \
states. We note that in our case the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[CapitalPsi]", 
        StyleBox["n", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\Psi_{n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "37ecec0d-faf9-1f4a-8988-12621ecec997"],
 " in the above working are the reduced radial wavefunctions, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["u", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["r", "TI"], 
         StyleBox["R", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "u(r)=rR(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3f9eccf4-6766-e84c-8b54-0da3670d7bb3"],
 ". So to implement this we need to, a) work out the additional potential \
term in the partner Hamiltonian, and b) find our new set of normalised \
wavefunctions. The first part we have done already, working out a gaussian \
fit to this, and we now want to approach the second part of the problem.\n\n\
In the gaussian basis we have \n(8) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"(", "1", ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["l", "TI"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "R^{(1)}(r)=\\sum_{i}N_{i}r^{l}e^{-\\left(\\frac{r}{\\alpha_{i}}\\right)^\
{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bee4b59a-e4a2-da4a-8b58-b8721ed66f53"],
 ",.\nThe eigenfunctions of (2) are thus\n(9) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "1", ")"}]], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{
            StyleBox["l", "TI"], "+", "1"}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\Psi_{n}^{(1)}=\\sum_{i}c_{i}N_{i}r^{l+1}e^{-\\left(\\frac{r}{\\alpha_{\
i}}\\right)^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "774c91c0-5c8b-9a4a-b624-19fd6a745eb4"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["c", "TI"], 
        StyleBox["i", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "c_{i}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "39c98665-3a77-7d46-9754-2b1a36ec4361"],
 " are mixing coefficients that specify the state. Thus our new \
eigenfunctions are\n(10) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "2", ")"}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["A", "TI"], "-"], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "1", ")"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Psi_{n}^{(2)}=A^{-}\\Psi_{n}^{(1)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6567e06c-6c78-dd4a-9f89-23e5a16e762f"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox[
              StyleBox["d", "TI"], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]], "+", 
             SuperscriptBox[
              StyleBox["W", "TI"], "1"]}], ")"}], 
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "1", ")"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "= \\left(-\\frac{d}{dr}+W^{1}\\right)\\Psi_{n}^{(1)}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b3667586-dd1a-7540-9ac7-7d5c26cf627f"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", "-", 
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            SubsuperscriptBox["\[CapitalPsi]", 
             StyleBox["n", "TI"], 
             RowBox[{"(", "1", ")"}]]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]], "+", 
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            SubsuperscriptBox["\[CapitalPsi]", "0", 
             RowBox[{"(", "1", ")"}]]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]], 
         FractionBox[
          SubsuperscriptBox["\[CapitalPsi]", 
           StyleBox["n", "TI"], 
           RowBox[{"(", "1", ")"}]], 
          SubsuperscriptBox["\[CapitalPsi]", "0", 
           RowBox[{"(", "1", ")"}]]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "=-\\frac{d\\Psi_{n}^{(1)}}{dr}+\\frac{d\\Psi_{0}^{(1)}}{dr}\\frac{\\Psi_\
{n}^{(1)}}{\\Psi_{0}^{(1)}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "14f67352-6b60-a240-9b57-8a66530e8f55"],
 ".\nWe write\n(11) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPsi]", "0", 
          RowBox[{"(", "1", ")"}]], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{
            StyleBox["l", "TI"], "+", "1"}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\Psi_{0}^{(1)}=\\sum_{i}a_{i}N_{i}r^{l+1}e^{-\\left(\\frac{r}{\\alpha_{\
i}}\\right)^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a3a834aa-5ccd-2747-891f-d478365cebe6"],
 ",\nto differentiate the ground state from the general case. Differentiating \
the expressions in (9) and (11) gives us \n(12) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPsi]", 
          StyleBox["n", "TI"], 
          RowBox[{"(", "2", ")"}]], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         FractionBox[
          RowBox[{"2", 
            SuperscriptBox[
             StyleBox["r", "TI"], 
             RowBox[{
               StyleBox["l", "TI"], "+", "2"}]]}], 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["i", "TI"], "2"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\Psi_{n}^{(2)}=\\sum_{i}c_{i}N_{i}\\frac{2r^{l+2}}{\\alpha_{i}^{2}}e^{-\
\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "90c3fd6e-5165-174d-a369-665673c3bfcf"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", "(", 
         RowBox[{
           UnderscriptBox["\[Sum]", 
            StyleBox["i", "TI"], LimitsPositioning -> True], 
           SubscriptBox[
            StyleBox["a", "TI"], 
            StyleBox["i", "TI"]], 
           SubscriptBox[
            StyleBox["N", "TI"], 
            StyleBox["i", "TI"]], 
           FractionBox[
            RowBox[{"2", 
              SuperscriptBox[
               StyleBox["r", "TI"], 
               RowBox[{
                 StyleBox["l", "TI"], "+", "2"}]]}], 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["i", "TI"], "2"]], 
           SuperscriptBox[
            StyleBox["e", "TI"], 
            RowBox[{"-", 
              SuperscriptBox[
               RowBox[{"(", 
                 FractionBox[
                  StyleBox["r", "TI"], 
                  SubscriptBox["\[Alpha]", 
                   StyleBox["i", "TI"]]], ")"}], "2"]}]]}], ")"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "-\\left(\\sum_{i}a_{i}N_{i}\\frac{2r^{l+2}}{\\alpha_{i}^{2}}e^{-\\left(\
\\frac{r}{\\alpha_{i}}\\right)^{2}}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6fad2a8d-a8f2-8b46-a1d7-e68b312ec2a3"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         FractionBox[
          RowBox[{
            UnderscriptBox["\[Sum]", 
             StyleBox["i", "TI"], LimitsPositioning -> True], 
            SubscriptBox[
             StyleBox["c", "TI"], 
             StyleBox["i", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["i", "TI"]], 
            SuperscriptBox[
             StyleBox["r", "TI"], 
             RowBox[{
               StyleBox["l", "TI"], "+", "1"}]], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               SuperscriptBox[
                RowBox[{"(", 
                  FractionBox[
                   StyleBox["r", "TI"], 
                   SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]]}], 
          RowBox[{
            UnderscriptBox["\[Sum]", 
             StyleBox["i", "TI"], LimitsPositioning -> True], 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["i", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["i", "TI"]], 
            SuperscriptBox[
             StyleBox["r", "TI"], 
             RowBox[{
               StyleBox["l", "TI"], "+", "1"}]], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               SuperscriptBox[
                RowBox[{"(", 
                  FractionBox[
                   StyleBox["r", "TI"], 
                   SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]]}]], ")"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\left(\\frac{\\sum_{i}c_{i}N_{i}r^{l+1}e^{-\\left(\\frac{r}{\\alpha_{i}\
}\\right)^{2}}}{\\sum_{i}a_{i}N_{i}r^{l+1}e^{-\\left(\\frac{r}{\\alpha_{i}}\\\
right)^{2}}}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bae4c5e4-9f8b-ea44-b9ad-4c0ec7b9f561"],
 ".\nEquation 12 is unwieldy, and would be a pain to calculate matrix \
elements with. We can instead use that, as for the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], 
         SubscriptBox[
          StyleBox["W", "TI"], "1"], "/", 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "dW_{1}/dr", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed9e4f98-9194-7f48-930a-caf6b468a0a6"],
 " term in (6), we can fit a set of gaussians to the fixed ground state in \
the second term. Thus we have\n(13) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalOmega]", 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            UnderscriptBox["\[Sum]", 
             StyleBox["i", "TI"], LimitsPositioning -> True], 
            SubscriptBox[
             StyleBox["c", "TI"], 
             StyleBox["i", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["i", "TI"]], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               SuperscriptBox[
                RowBox[{"(", 
                  FractionBox[
                   StyleBox["r", "TI"], 
                   SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]]}], 
          RowBox[{
            UnderscriptBox["\[Sum]", 
             StyleBox["i", "TI"], LimitsPositioning -> True], 
            FractionBox[
             RowBox[{
               SubscriptBox[
                StyleBox["c", "TI"], 
                StyleBox["i", "TI"]], 
               SubscriptBox[
                StyleBox["N", "TI"], 
                StyleBox["i", "TI"]]}], 
             SubsuperscriptBox["\[Alpha]", 
              StyleBox["i", "TI"], "2"]], 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{"-", 
               SuperscriptBox[
                RowBox[{"(", 
                  FractionBox[
                   StyleBox["r", "TI"], 
                   SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]]}]], "\[TildeTilde]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["m", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["m", "TI"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SubscriptBox["\[Omega]", 
             StyleBox["m", "TI"]], 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\Omega(r)=\\frac{\\sum_{i}c_{i}N_{i}e^{-\\left(\\frac{r}{\\alpha_{i}}\\\
right)^{2}}}{\\sum_{i}\\frac{c_{i}N_{i}}{\\alpha_{i}^{2}}e^{-\\left(\\frac{r}{\
\\alpha_{i}}\\right)^{2}}}\\approx\\sum_{m}c_{m}e^{-\\omega_{m}r^{2}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a1109086-bc6b-1b41-aae7-d01d14625dfd"],
 ",\nwhere the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["c", "TI"], 
        StyleBox["m", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "c_{m}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "043a1606-e263-f24b-a8ec-24dc5327eeae"],
 " are determined by fitting and, after dividing by a factor of r, our new \
radial wavefunctions are given by\n(14) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["R", "TI"], 
          RowBox[{"(", "2", ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["i", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["i", "TI"]], 
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", "2", ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "R^{(2)}(r)=\\sum_{i}c_{i}\\Phi_{i}^{(2)}(r)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0f63d1b0-114e-4442-a974-3f9d67fa8029"],
 ", \n(15) ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"], 
          RowBox[{"(", "2", ")"}]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"], 
          RowBox[{"(", "2", ")"}]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["2", 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "2"]], "-", "\[CapitalOmega]", 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{
            StyleBox["l", "TI"], "+", "1"}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\Phi_{i}^{(2)}(r)=N_{i}^{(2)}\\left(\\frac{2}{\\alpha_{i}^{2}}-\\Omega(\
r)\\right)r^{l+1}e^{-\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c30ab806-28fd-1246-826b-609a77791967"],
 ",\n"
}], "Text",
 CellChangeTimes->{{3.9852487450516777`*^9, 3.985248921678831*^9}, {
   3.9852490208054028`*^9, 3.9852490394336834`*^9}, {3.9852491178060284`*^9, 
   3.985249128952379*^9}, {3.9852493784802074`*^9, 3.9852493992288303`*^9}, {
   3.985249452211687*^9, 3.9852495339625607`*^9}, {3.985249638241272*^9, 
   3.9852497603212643`*^9}, 3.9852498068668118`*^9, 3.985249854409689*^9, {
   3.985249914100321*^9, 3.9852499774856377`*^9}, {3.9852501343682404`*^9, 
   3.98525014005781*^9}, {3.985250639866848*^9, 3.9852507782171307`*^9}, {
   3.9852518630822277`*^9, 3.9852518757736244`*^9}, {3.985251920929268*^9, 
   3.9852519264995155`*^9}, {3.9852519950236416`*^9, 
   3.9852520967832737`*^9}, {3.9852522540524464`*^9, 
   3.9852522684866657`*^9}, {3.98525265459622*^9, 3.985252657246664*^9}, {
   3.985252693670738*^9, 3.9852527272838936`*^9}, {3.9852528122887897`*^9, 
   3.9852528447881584`*^9}, {3.9854079105316257`*^9, 
   3.9854079321591873`*^9}, {3.985407970127825*^9, 
   3.9854079726408176`*^9}},ExpressionUUID->"8b8b8a0f-55fe-4e40-a305-\
f58f305f62b1"],

Cell[TextData[{
 "We now have wavefunctions and a Hamiltonian for our supersymmetric \
potential, we now want to start doing calculations with it. From here we drop \
the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", "2", ")"}], TraditionalForm], "errors" -> {}, "input" -> 
     "(2)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2a92b81e-f3b7-cf4a-a554-cb2ccf314861"],
 " notation, but note that all the following are derived for the \
supersymmetric partner only. We first want the normalisation,\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], 
         SuperscriptBox[
          RowBox[{"(", 
            StyleBox["r", "TI"], ")"}], "2"], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\int_{0}^{\\infty}\\Phi_{i}(r)^{2}r^{2}dr=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "86c0ab65-f7c0-5445-94c5-613c22412d83"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"], "2"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{"2", 
            StyleBox["l", "TI"], "+", "4"}]], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              FractionBox["2", 
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["i", "TI"], "2"]], "-", "\[CapitalOmega]", 
              RowBox[{"(", 
                StyleBox["r", "TI"], ")"}]}], ")"}], "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "=N_{i}^{2}\\int_{0}^{\\infty}r^{2l+4}\\left(\\frac{2}{\\alpha_{i}^{2}}-\
\\Omega(r)\\right)^{2}e^{-2\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}dr", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "969d46c9-ca45-014e-b106-873f90b426fe"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"1", "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"], "2"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{"2", 
            StyleBox["l", "TI"], "+", "4"}]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["4", 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "4"]], "-", "4", 
             FractionBox[
              RowBox[{"\[CapitalOmega]", "(", 
                StyleBox["r", "TI"], ")"}], 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "2"]], "+", "\[CapitalOmega]", 
             SuperscriptBox[
              RowBox[{"(", 
                StyleBox["r", "TI"], ")"}], "2"]}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-2", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "1=N_{i}^{2}\\int_{0}^{\\infty}r^{2l+4}\\left(\\frac{4}{\\alpha_{i}^{4}}-\
4\\frac{\\Omega(r)}{\\alpha_{i}^{2}}+\\Omega(r)^{2}\\right)e^{-2\\left(\\frac{\
r}{\\alpha_{i}}\\right)^{2}}dr", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4210a427-43ab-574d-bc20-db7376c1f673"],
 ",\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"], "2"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["4", 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "4"]], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-2", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             StyleBox["d", "TI"], 
             StyleBox["r", "TI"], "-", 
             FractionBox["4", 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "2"]], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-2", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             UnderscriptBox["\[Sum]", 
              StyleBox["m", "TI"], LimitsPositioning -> True], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["m", "TI"]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SubscriptBox["\[Omega]", 
                 StyleBox["m", "TI"]], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]], "+", 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-2", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             UnderscriptBox["\[Sum]", 
              RowBox[{
                StyleBox["m", "TI"], ",", 
                StyleBox["n", "TI"]}], LimitsPositioning -> True], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["m", "TI"]], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["n", "TI"]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SubscriptBox["\[Omega]", 
                 StyleBox["m", "TI"]], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SubscriptBox["\[Omega]", 
                 StyleBox["n", "TI"]], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "=N_{i}^{2}\\left(\\frac{4}{\\alpha_{i}^{4}}\\int_{0}^{\\infty}r^{2l+4}e^\
{-2\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}dr-\\frac{4}{\\alpha_{i}^{2}}\\\
int_{0}^{\\infty}r^{2l+4}e^{-2\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}\\sum_\
{m}c_{m}e^{-\\omega_{m}r^{2}}+\\int_{0}^{\\infty}r^{2l+4}e^{-2\\left(\\frac{r}\
{\\alpha_{i}}\\right)^{2}}\\sum_{m,n}c_{m}c_{n}e^{-\\omega_{m} \
r^{2}}e^{-\\omega_{n} r^{2}}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d1743816-ca56-2848-b6de-39f55998421b"],
 "."
}], "Text",
 CellChangeTimes->{{3.985252732586561*^9, 3.9852527663928795`*^9}, {
  3.9852528501548576`*^9, 3.985252862361761*^9}, {3.985252905235405*^9, 
  3.9852529983081417`*^9}, {3.985253031394335*^9, 3.985253037657173*^9}, {
  3.985253591191206*^9, 3.9852536438465347`*^9}, {3.9852537527202606`*^9, 
  3.9852537960779247`*^9}, {3.985253832186249*^9, 3.9852538336252537`*^9}, {
  3.985404349908119*^9, 3.9854043549601135`*^9}, {3.9854044134022026`*^9, 
  3.985404413615671*^9}},ExpressionUUID->"44ee3893-5a1d-4d40-ace0-\
be08e057b7ad"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GaussWaveFunc", "[", 
   RowBox[{"r_", ",", " ", "l_", ",", "\[Alpha]_"}], "]"}], ":=", 
  RowBox[{
   SuperscriptBox["r", 
    RowBox[{"l", "+", "1"}]], 
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"r", "/", "\[Alpha]"}], ")"}], "2"]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
