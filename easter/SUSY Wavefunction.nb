Cell[TextData[{
 "So we have\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "O_{ij}=", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0f0d657c-70e9-0242-83cc-b56e86f02ab2"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         FractionBox[
          RowBox[{"\[CapitalGamma]", "(", 
            RowBox[{
              FractionBox["5", "2"], "+", 
              StyleBox["l", "TI"]}], ")"}], "2"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["4", 
              RowBox[{
                SubsuperscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"], "2"], 
                SubsuperscriptBox["\[Alpha]", 
                 StyleBox["j", "TI"], "2"]}]], 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"]], "+", 
                  FractionBox["1", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"], "2"]]}], ")"}], 
              RowBox[{"-", 
                FractionBox["5", "2"], "-", 
                StyleBox["l", "TI"]}]], "-", 
             RowBox[{"(", 
               RowBox[{
                 FractionBox["2", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["i", "TI"], "2"]], "+", 
                 FractionBox["2", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["j", "TI"], "2"]]}], ")"}], 
             UnderscriptBox["\[Sum]", 
              StyleBox["m", "TI"], LimitsPositioning -> True], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["m", "TI"]], 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"]], "+", 
                  FractionBox["1", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"], "2"]], "+", 
                  SubscriptBox["\[Omega]", 
                   StyleBox["m", "TI"]]}], ")"}], 
              RowBox[{"-", 
                FractionBox["5", "2"], "-", 
                StyleBox["l", "TI"]}]], "+", 
             UnderscriptBox["\[Sum]", 
              StyleBox["m", "TI"], LimitsPositioning -> True], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["m", "TI"]], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["n", "TI"]], 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  FractionBox["1", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"]], "+", 
                  FractionBox["1", 
                   SubsuperscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"], "2"]], "+", 
                  SubscriptBox["\[Omega]", 
                   StyleBox["m", "TI"]], "+", 
                  SubscriptBox["\[Omega]", 
                   StyleBox["n", "TI"]]}], ")"}], 
              RowBox[{"-", 
                FractionBox["5", "2"], "-", 
                StyleBox["l", "TI"]}]]}]}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "N_{i}N_{j}\\frac{\\Gamma(\\frac{5}{2}+l)}{2}\\left(\\frac{4}{\\alpha_{i}\
^{2}\\alpha_{j}^{2}}\\left(\\frac{1}{\\alpha_{i}^{2}}+\\frac{1}{\\alpha_{j}^{\
2}}\\right)^{-\\frac{5}{2}-l}-\\left(\\frac{2}{\\alpha_{i}^{2}}+\\frac{2}{\\\
alpha_{j}^{2}}\\right)\\sum_{m}c_{m}\\left(\\frac{1}{\\alpha_{i}^{2}}+\\frac{\
1}{\\alpha_{j}^{2}}+\\omega_{m}\\right)^{-\\frac{5}{2}-l}+\\sum_{m}c_{m}c_{n}\
\\left(\\frac{1}{\\alpha_{i}^{2}}+\\frac{1}{\\alpha_{j}^{2}}+\\omega_{m}+\\\
omega_{n}\\right)^{-\\frac{5}{2}-l}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8b0336a7-79f9-e24a-9ca9-ada058231b3d"]
}], "Text",
