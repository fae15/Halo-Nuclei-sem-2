Cell[TextData[{
 "Hence for our normalisation we have \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              FractionBox[
               RowBox[{"\[CapitalGamma]", "(", 
                 RowBox[{
                   FractionBox["5", "2"], "+", 
                   StyleBox["l", "TI"]}], ")"}], "2"], "(", 
              RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"], "2"], ")"}], 
                 RowBox[{
                   FractionBox["1", "2"], "+", 
                   StyleBox["l", "TI"]}]], "-", 
                FractionBox["4", 
                 SubsuperscriptBox["\[Alpha]", 
                  StyleBox["i", "TI"], "2"]], 
                UnderscriptBox["\[Sum]", 
                 StyleBox["m", "TI"], LimitsPositioning -> True], 
                FractionBox[
                 SubscriptBox[
                  StyleBox["c", "TI"], 
                  StyleBox["m", "TI"]], 
                 SuperscriptBox[
                  RowBox[{"(", 
                    RowBox[{
                    FractionBox["2", 
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"]], "+", 
                    SubscriptBox["\[Omega]", 
                    StyleBox["m", "TI"]]}], ")"}], 
                  RowBox[{
                    FractionBox["5", "2"], "+", 
                    StyleBox["l", "TI"]}]]], "+", 
                UnderscriptBox["\[Sum]", 
                 RowBox[{
                   StyleBox["m", "TI"], ",", 
                   StyleBox["n", "TI"]}], LimitsPositioning -> True], 
                FractionBox[
                 RowBox[{
                   SubscriptBox[
                    StyleBox["c", "TI"], 
                    StyleBox["m", "TI"]], 
                   SubscriptBox[
                    StyleBox["c", "TI"], 
                    StyleBox["n", "TI"]]}], 
                 SuperscriptBox[
                  RowBox[{"(", 
                    RowBox[{
                    FractionBox["2", 
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"]], "+", 
                    SubscriptBox["\[Omega]", 
                    StyleBox["m", "TI"]], "+", 
                    SubscriptBox["\[Omega]", 
                    StyleBox["n", "TI"]]}], ")"}], 
                  RowBox[{
                    FractionBox["5", "2"], "+", 
                    StyleBox["l", "TI"]}]]]}], ")"}], ")"}], 
          RowBox[{"-", 
            FractionBox["1", "2"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "N_{i}=\\left(\\frac{\\Gamma(\\frac{5}{2}+l)}{2}\\left(\\left(\\frac{\\\
alpha_{i}^{2}}{2}\\right)^{\\frac{1}{2}+l}-\\frac{4}{\\alpha_{i}^{2}}\\sum_{m}\
\\frac{c_{m}}{\\left(\\frac{2}{\\alpha_{i}^{2}}+\\omega_{m}\\right)^{\\frac{5}\
{2}+l}}+\\sum_{m,n}\\frac{c_{m}c_{n}}{\\left(\\frac{2}{\\alpha_{i}^{2}}+\\\
omega_{m}+\\omega_{n}\\right)^{\\frac{5}{2}+l}}\\right)\\right)^{-\\frac{1}{2}\
}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf961a28-ccfc-d74b-bae4-ab1431e17180"],
 " .\n\nThe overlap wavefunctions can be calculated by\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], "|", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["j", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SuperscriptBox[
          StyleBox["r", "TI"], "2"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle \
i|j\\rangle=O_{ij}=\\int_{0}^{\\infty}\\Phi_{i}(r)\\Phi_{j}(r)r^{2}dr", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "854a9d1f-fce9-a641-88a0-c483e0789ed6"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          RowBox[{"2", 
            StyleBox["l", "TI"], "+", "4"}]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["2", 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["i", "TI"], "2"]], "-", "\[CapitalOmega]", 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["2", 
              SubsuperscriptBox["\[Alpha]", 
               StyleBox["j", "TI"], "2"]], "-", "\[CapitalOmega]", 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]], ")"}], "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               FractionBox[
                StyleBox["r", "TI"], 
                SubscriptBox["\[Alpha]", 
                 StyleBox["j", "TI"]]], ")"}], "2"]}]], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "=N_{i}N_{j}\\int_{0}^{\\infty}r^{2l+4}\\left(\\frac{2}{\\alpha_{i}^{2}}-\
\\Omega(r)\\right)\\left(\\frac{2}{\\alpha_{j}^{2}}-\\Omega(r)\\right)e^{-\\\
left(\\frac{r}{\\alpha_{i}\\right)^{2}}e^{-\\left(\\frac{r}{\\alpha_{j}\\\
right)^{2}}dr", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "22148548-d558-a940-8af2-24bbd0397261"],
 "\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["4", 
              RowBox[{
                SubsuperscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"], "2"], 
                SubsuperscriptBox["\[Alpha]", 
                 StyleBox["j", "TI"], "2"]}]], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]], ")"}], "2"]}]], 
             StyleBox["d", "TI"], 
             StyleBox["r", "TI"], "-", 
             RowBox[{"(", 
               RowBox[{
                 FractionBox["2", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["i", "TI"], "2"]], "+", 
                 FractionBox["2", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["j", "TI"], "2"]]}], ")"}], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], "\[CapitalOmega]", 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]], ")"}], "2"]}]], 
             StyleBox["d", "TI"], 
             StyleBox["r", "TI"], "+", 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], "\[CapitalOmega]", 
             SuperscriptBox[
              RowBox[{"(", 
                StyleBox["r", "TI"], ")"}], "2"], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]], ")"}], "2"]}]], 
             StyleBox["d", "TI"], 
             StyleBox["r", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "=N_{i}N_{j}\\left(\\frac{4}{\\alpha_{i}^{2}\\alpha_{j}^{2}}\\int_{0}^{\\\
infty}r^{2l+4}e^{-\\left(\\frac{r}{\\alpha_{i}\\right)^{2}}e^{-\\left(\\frac{\
r}{\\alpha_{j}\\right)^{2}}dr-\\left(\\frac{2}{\\alpha_{i}^{2}}+\\frac{2}{\\\
alpha_{j}^{2}}\\right)\\int_{0}^{\\infty}r^{2l+4}\\Omega(r)e^{-\\left(\\frac{\
r}{\\alpha_{i}\\right)^{2}}e^{-\\left(\\frac{r}{\\alpha_{j}\\right)^{2}}dr+\\\
int_{0}^{\\infty}r^{2l+4}\\Omega(r)^{2}e^{-\\left(\\frac{r}{\\alpha_{i}\\\
right)^{2}}e^{-\\left(\\frac{r}{\\alpha_{j}\\right)^{2}}dr\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f902025-233d-454d-895a-28fae7883532"],
 "\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", 
              RowBox[{
                SubsuperscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"], "2"], 
                SubsuperscriptBox["\[Alpha]", 
                 StyleBox["j", "TI"], "2"]}]], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]], ")"}], "2"]}]], 
             StyleBox["d", "TI"], 
             StyleBox["r", "TI"], "-", 
             RowBox[{"(", 
               RowBox[{
                 FractionBox["2", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["i", "TI"], "2"]], "+", 
                 FractionBox["2", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["j", "TI"], "2"]]}], ")"}], 
             UnderscriptBox["\[Sum]", 
              StyleBox["m", "TI"], LimitsPositioning -> True], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["m", "TI"]], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SubscriptBox["\[Omega]", 
                 StyleBox["m", "TI"]], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]], ")"}], "2"]}]], 
             StyleBox["d", "TI"], 
             StyleBox["r", "TI"], "+", 
             UnderscriptBox["\[Sum]", 
              RowBox[{
                StyleBox["m", "TI"], ",", 
                StyleBox["n", "TI"]}], LimitsPositioning -> True], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["m", "TI"]], 
             SubscriptBox[
              StyleBox["c", "TI"], 
              StyleBox["n", "TI"]], 
             SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
             SuperscriptBox[
              StyleBox["r", "TI"], 
              RowBox[{"2", 
                StyleBox["l", "TI"], "+", "4"}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SuperscriptBox[
                 RowBox[{"(", 
                   FractionBox[
                    StyleBox["r", "TI"], 
                    SubscriptBox["\[Alpha]", 
                    StyleBox["j", "TI"]]], ")"}], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SubscriptBox["\[Omega]", 
                 StyleBox["m", "TI"]], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]], 
             SuperscriptBox[
              StyleBox["e", "TI"], 
              RowBox[{"-", 
                SubscriptBox["\[Omega]", 
                 StyleBox["n", "TI"]], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "=N_{i}N_{j}\\left(\\frac{1}{\\alpha_{i}^{2}\\alpha_{j}^{2}}\\int_{0}^{\\\
infty}r^{2l+4}e^{-\\left(\\frac{r}{\\alpha_{i}\\right)^{2}}e^{-\\left(\\frac{\
r}{\\alpha_{j}\\right)^{2}}dr-\\left(\\frac{2}{\\alpha_{i}^{2}}+\\frac{2}{\\\
alpha_{j}^{2}}\\right)\\sum_{m}c_{m}\\int_{0}^{\\infty}r^{2l+4}e^{-\\omega_{m}\
r^{2}}e^{-\\left(\\frac{r}{\\alpha_{i}\\right)^{2}}e^{-\\left(\\frac{r}{\\\
alpha_{j}\\right)^{2}}dr+\\sum_{m,n}c_{m}c_{n}\\int_{0}^{\\infty}r^{2l+4}e^{-\
\\left(\\frac{r}{\\alpha_{i}}\\right)^{2}}e^{-\\left(\\frac{r}{\\alpha_{j}}\\\
right)^{2}}e^{-\\omega_{m} r^{2}}e^{-\\omega_{n} r^{2}}\\right)", "state" -> 
     "Boxes"|>,
