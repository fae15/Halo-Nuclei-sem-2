(* Beginning of Notebook Content *)
Notebook[{
Cell[TextData[{
 "This follows the overleaf document shared by Jagjit and Niels, and seeks to \
derive antisymmetrized matrix elements for a three body system with a nuclear \
core of finite mass.\n\nUp until this point we have been working with the \
core neutron Hamiltonian ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox[
           StyleBox["H", "TI"], "^"], "cn"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox[
          RowBox[{
            StyleBox["A", "TI"], "+", "2"}], 
          RowBox[{"2", 
            StyleBox["m", "TI"], 
            StyleBox["A", "TI"]}]], 
         SubsuperscriptBox["\[Del]", 
          SubscriptBox[
           StyleBox["r", "TI"], 
           StyleBox["n", "TI"]], "2"], "+", 
         SubscriptBox[
          StyleBox["V", "TI"], "cn"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["r", "TI"], 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", 
          RowBox[{"2", "\[Mu]"}]], 
         SubsuperscriptBox["\[Del]", 
          SubscriptBox[
           StyleBox["r", "TI"], 
           StyleBox["n", "TI"]], "2"], "+", 
         SubscriptBox[
          StyleBox["V", "TI"], "cn"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["r", "TI"], 
            StyleBox["n", "TI"]], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\hat{H}_{\\text{cn}}=\\frac{h^{2}}{4\\pi^{2}}\\frac{A+2}{2mA}\\nabla^{\
2}_{r_{n}}+V_{\\text{cn}}(r_{n})=\\frac{h^{2}}{4\\pi^{2}}\\frac{1}{2\\mu}\\\
nabla^{2}_{r_{n}}+V_{\\text{cn}}(r_{n})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "83032e30-458a-2147-924f-6d2d4efc7a5d"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox[
           StyleBox["H", "TI"], "^"], "12"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", 
          RowBox[{"2", 
            StyleBox["m", "TI"], 
            StyleBox["A", "TI"]}]], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "1"]], "-", 
              SubscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "2"]]}], ")"}], "2"], "+", 
         StyleBox["V", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              OverscriptBox[
               StyleBox["r", "TI"], "\[RightVector]"], "1"], "-", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["r", "TI"], "\[RightVector]"], "2"]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\hat{H}_{12}=\\frac{h^{2}}{4\\pi^{2}}\\frac{1}{2mA}\\left(\\vec{\\\
nabla}_{r_{1}}-\\vec{\\nabla}_{r_{2}}\\right)^{2}+V(\\vec{r}_{1}-\\vec{r}_{2})\
", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8c991cd4-389e-4644-9861-bf3592c5a6cd"],
 " in the limit ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "A\\rightarrow\\infty", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d36b731c-2df2-ed46-9b16-69b20b788116"],
 ", with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["m", "TI"], 
            StyleBox["A", "TI"]}], 
          RowBox[{
            StyleBox["A", "TI"], "+", "2"}]], "\[Rule]", 
         StyleBox["m", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu=\\frac{mA}{A+2}\\rightarrow m", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7e540e03-df32-d548-867e-a284ab10114e"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["m", "TI"], TraditionalForm], "errors" -> {}, "input" -> "m", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b261e78c-d61b-8a49-b0be-f77f7a57a843"],
 " is the mass of a nucleon. We now want to relax this limit. For ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["H", "TI"], "^"], 
        RowBox[{
          StyleBox["c", "TI"], 
          StyleBox["n", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\hat{H}_{cn}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8de16257-23c4-6e41-8588-2c0447b2f520"],
 " this is done by letting ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "\[LongEqual]", 
         FractionBox["4", "6"], 
         StyleBox["m", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mu=\\frac{4}{6}m", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7b1d06a1-da5b-8b4a-8890-6362924a25e2"],
 ", so making only a small numeric change to the kinetic matrix elements, but \
in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["H", "TI"], "^"], "12"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\hat{H}_{12}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bdad849c-e86a-774b-9557-94ce1c9e9b7b"],
 " we now have to include the term involving relative motion between the two \
neutrons about the core. We label this new term ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox[
           StyleBox["T", "TI"], "^"], "12"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", 
          RowBox[{"2", 
            StyleBox["m", "TI"], 
            StyleBox["A", "TI"]}]], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "1"]], "-", 
              SubscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "2"]]}], ")"}], "2"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", 
          RowBox[{"2", "\[Mu]", 
            RowBox[{"(", 
              RowBox[{"2", "+", 
                StyleBox["A", "TI"]}], ")"}]}]], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "1"]], "-", 
              SubscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "2"]]}], ")"}], "2"]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "\\hat{T}_{12}=\\frac{h^{2}}{4\\pi^{2}}\\frac{1}{2mA}\\left(\\vec{\\\
nabla}_{r_{1}}-\\vec{\\nabla}_{r_{2}}\\right)^{2}=\\frac{h^{2}}{4\\pi^{2}}\\\
frac{1}{2\\mu(2+A)}\\left(\\vec{\\nabla}_{r_{1}}-\\vec{\\nabla}_{r_{2}}\\\
right)^{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f8cc78ec-d9d0-8040-8ebe-a1a0e719292e"],
 " and consider how we get matrix elements for this. We have ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["i", "TI"], ",", 
         StyleBox["j", "TI"], "\[RightAngleBracket]", "\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Psi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[Psi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], "-", 
             SubscriptBox["\[Psi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], 
             SubscriptBox["\[Psi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "|i,j\\rangle=N_{ij}\\left(\\psi_{i}(\\vec{r}_{1})\\psi_{j}(\\vec{r}_{2})\
-\\psi_{i}(\\vec{r}_{2})\\psi_{j}(\\vec{r}_{1})\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a8ae175-4c86-1d4b-a190-0d17623d0950"],
 ", where we are not using the gaussian basis functions ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[CapitalPhi]", TraditionalForm], "errors" -> {}, 
     "input" -> "\\Phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1d25ecfc-d158-f240-8942-52d3721f9dec"],
 " as we cannot assume that the angular terms can be factored out when the \
matrix elements are calculated. The matrix element is \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["T", "TI"], "^"], "12"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              OverscriptBox["\[Psi]", "_"], 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox[
              OverscriptBox["\[Psi]", "_"], 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], "-", 
             SubscriptBox[
              OverscriptBox["\[Psi]", "_"], 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], 
             SubscriptBox[
              OverscriptBox["\[Psi]", "_"], 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}]}], ")"}], 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox["1", 
          RowBox[{"2", "\[Mu]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["A", "TI"], "+", "2"}], ")"}]}]], 
         SubscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubsuperscriptBox["\[Del]", 
               SubscriptBox[
                StyleBox["r", "TI"], "1"], "2"], "+", 
              SubsuperscriptBox[
               OverscriptBox["\[Del]", "\[RightVector]"], 
               SubscriptBox[
                StyleBox["r", "TI"], "2"], "2"], "-", "2", 
              RowBox[{
                SubscriptBox[
                 OverscriptBox["\[Del]", "\[RightVector]"], 
                 SubscriptBox[
                  StyleBox["r", "TI"], "1"]], "\[CenterDot]", 
                SubscriptBox[
                 OverscriptBox["\[Del]", "\[RightVector]"], 
                 SubscriptBox[
                  StyleBox["r", "TI"], "2"]]}]}], ")"}], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["l", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Psi]", 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[Psi]", 
              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], "-", 
             SubscriptBox["\[Psi]", 
              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[Psi]", 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle i,j|\\hat{T}_{12}|k,l\\rangle=\\int d^{3}\\vec{r}_{1}\\int \
d^{3}\\vec{r}_{2}N_{ij}\\left(\\bar{\\psi}_{i}(\\vec{r}_{1})\\bar{\\psi}_{j}(\
\\vec{r}_{2})-\\bar{\\psi}_{i}(\\vec{r}_{2})\\bar{\\psi}_{j}(\\vec{r}_{1})\\\
right)\\frac{h^{2}}{4\\pi^{2}}\\frac{1}{2\\mu(A+2)}\\left(\\nabla_{r_{1}}^{2}+\
\\vec{\\nabla}_{r_{2}}^{2}-2{\\vec{\\nabla}_{r_{1}}\\cdot\\vec{\\nabla}_{r_{2}\
}\\right)\\N_{kl}\\left(\\psi_{k}(\\vec{r}_{1})\\psi_{l}(\\vec{r}_{2})-\\psi_{\
l}(\\vec{r}_{1})\\psi_{k}(\\vec{r}_{2})\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8db89284-2cde-a94a-b3e4-33d171f7f191"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox["\[Psi]", "_"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\bar{\\psi}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed9a01f4-5085-ad48-9816-6a2c0d0b3112"],
 " is the complex conjugate of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Psi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\psi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "00c6ea8f-89b1-da41-a6ee-35b6faf002a0"],
 " (important when considering spherical harmonic functions). It is simple to \
show that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              OverscriptBox["\[Del]", "\[RightVector]"], 
              SubscriptBox[
               StyleBox["r", "TI"], "1"]], "\[CenterDot]", 
             SubscriptBox[
              OverscriptBox["\[Del]", "\[RightVector]"], 
              SubscriptBox[
               StyleBox["r", "TI"], "2"]]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Psi]", 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[Psi]", 
              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}]}], ")"}],
          "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              OverscriptBox["\[Del]", "\[RightVector]"], 
              SubscriptBox[
               StyleBox["r", "TI"], "1"]], 
             SubscriptBox["\[Psi]", 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}]}], ")"}],
          "\[CenterDot]", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              OverscriptBox["\[Del]", "\[RightVector]"], 
              SubscriptBox[
               StyleBox["r", "TI"], "2"]], 
             SubscriptBox["\[Psi]", 
              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\left(\\vec{\\nabla}_{r_{1}}\\cdot\\vec{\\nabla}_{r_{2}}\\right)\\left(\
\\psi_{k}(\\vec{r}_{1})\\psi_{l}(\\vec{r}_{2})\\right)=\\left(\\vec{\\nabla}_{\
r_{1}}\\psi_{k}(\\vec{r}_{1})\\right)\\cdot\\left(\\vec{\\nabla}_{r_{2}}\\psi_\
{l}(\\vec{r}_{2})\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c07a0170-240d-9349-842d-e27352ecbacc"],
 ". Using our previous definitions for the matrix elements we find (after \
evaluating some terms),#\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["T", "TI"], "^"], "12"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["N", "TI"], 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             RowBox[{
               StyleBox["k", "TI"], 
               StyleBox["l", "TI"]}]]}], 
          RowBox[{"2", "\[Mu]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["A", "TI"], "+", "2"}], ")"}]}]], 
         RowBox[{"[", 
           RowBox[{
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], "-", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], "-", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], "+", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]]}], ")"}], "+", 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], "-", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], "-", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], "+", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]]}], ")"}], "-", "2", "\[Integral]", 
             SuperscriptBox[
              StyleBox["d", "TI"], "3"], 
