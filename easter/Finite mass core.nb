              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}]}], ")"}],
          "\[LongEqual]", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["D", "TI"], "\[RightVector]"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], "\[CenterDot]", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["D", "TI"], "\[RightVector]"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["l", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
