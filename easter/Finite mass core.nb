Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["T", "TI"], "^"], "12"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         "2", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["N", "TI"], 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             RowBox[{
               StyleBox["k", "TI"], 
               StyleBox["l", "TI"]}]]}], 
          RowBox[{"2", "\[Mu]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["A", "TI"], "+", "2"}], ")"}]}]], 
         RowBox[{"[", 
           RowBox[{
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], "-", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], "-", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], "+", 
                 SubscriptBox[
                  StyleBox["T", "TI"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], 
                 SubscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]]}], ")"}], "-", 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]], "\[CenterDot]", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], "+", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["l", "TI"]}]], "\[CenterDot]", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["k", "TI"]}]], "-", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]], "\[CenterDot]", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], "-", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["j", "TI"], 
                    StyleBox["k", "TI"]}]], "\[CenterDot]", 
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["D", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["l", "TI"]}]]}], ")"}]}], "]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle \
i,j|\\hat{T}_{12}|k,l\\rangle=2\\frac{h^{2}}{4\\pi^{2}}\\frac{N_{ij}N_{kl}}{2\
\\mu(A+2)}\\left[\\left(T_{ik}O_{jl}-T_{il}O_{jk}-T_{jk}O_{il}+T_{jl}O_{ik}\\\
right)-\\left(\\vec{D}_{ik}\\cdot\\vec{D}_{jl}+\\vec{D}_{jl}\\cdot\\vec{D}_{\
ik}-\\vec{D}_{il}\\cdot\\vec{D}_{jk}-\\vec{D}_{jk}\\cdot\\vec{D}_{il}\\right)\
\\right]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e56b0971-1a1f-8b4b-9c21-565d6d97cd34"],
 "\nRecognising the first term as the negative of the expression for the \
core-neutron kinetic matrix element, we also assume that the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox[
           StyleBox["D", "TI"], "\[RightVector]"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], "\[CenterDot]", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["D", "TI"], "\[RightVector]"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["l", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\vec{D}_{ik}\\cdot\\vec{D}_{jl}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "033d2a8b-4794-8348-bfb2-9de9006fbf5c"],
 " commute, which gives us\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["T", "TI"], "^"], "12"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         "-", 
         FractionBox["2", 
          RowBox[{
            StyleBox["A", "TI"], "+", "2"}]], 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["T", "TI"], "^"], 
              StyleBox["n", "TI"]], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"]}], "\[RightAngleBracket]"}], "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"4", 
            SuperscriptBox["\[Pi]", "2"]}]], 
         FractionBox[
          RowBox[{"4", 
            SubscriptBox[
             StyleBox["N", "TI"], 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["j", "TI"]}]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             RowBox[{
               StyleBox["k", "TI"], 
               StyleBox["l", "TI"]}]]}], 
          RowBox[{"2", "\[Mu]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["A", "TI"], "+", "2"}], ")"}]}]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              OverscriptBox[
               StyleBox["D", "TI"], "\[RightVector]"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], "\[CenterDot]", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["D", "TI"], "\[RightVector]"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["l", "TI"]}]], "-", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["D", "TI"], "\[RightVector]"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["l", "TI"]}]], "\[CenterDot]", 
             SubscriptBox[
              OverscriptBox[
               StyleBox["D", "TI"], "\[RightVector]"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\langle i,j|\\hat{T}_{12}|k,l\\rangle=-\\frac{2}{A+2}\\langle \
i,j|\\hat{T}_{n}|k,l\\rangle-\\frac{h^{2}}{4\\pi^{2}}\\frac{4N_{ij}N_{kl}}{2\\\
mu(A+2)}\\left(\\vec{D}_{ik}\\cdot\\vec{D}_{jl}-\\vec{D}_{il}\\cdot\\vec{D}_{\
jk}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b211538c-30f8-bf4b-b787-b08965264a43"]
}], "Text",
 CellChangeTimes->{
  3.9846616355289803`*^9, 3.9846617516876583`*^9, {3.984661847044714*^9, 
   3.9846618781003876`*^9}, {3.9846619247514*^9, 3.9846619793080845`*^9}, {
   3.9846620356040115`*^9, 
   3.9846620480206127`*^9}},ExpressionUUID->"e8dd0dc5-950c-754b-a8ef-\
ae9bcde05157"],

