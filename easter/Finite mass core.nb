Cell[TextData[{
 "We now want to consider how these matrix elements of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["D", "TI"], "\[RightVector]"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["k", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\vec{D}_{ik}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "97d05aed-6c72-fc40-94de-5b8e2c99ab6d"],
 " will behave. We define our wavefunctions be be of the form ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Psi]", 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           OverscriptBox[
            StyleBox["r", "TI"], "\[RightVector]"], ")"}], "\[LongEqual]", 
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         SubsuperscriptBox[
          StyleBox["Y", "TI"], 
          StyleBox["l", "TI"], 
          StyleBox["m", "TI"]], 
         RowBox[{"(", 
           RowBox[{"\[Theta]", ",", "\[Phi]"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\psi_{i}(\\vec{r})=\\Phi_{i}(r)Y_{l}^{m}(\\theta,\\phi)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "100a6d56-f41b-3843-bd28-1dd68843b8ac"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Phi_{i}(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9ae126fb-9b55-3049-84a2-67d023b4754c"],
 " are our previously defined gaussian wavefunctions, and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["Y", "TI"], 
        StyleBox["l", "TI"], 
        StyleBox["m", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "Y_{l}^{m}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "702d1fb0-d2fd-cb4a-abcf-4ae0a1e21c61"],
 " are the spherical harmonics. Ignoring the normalisation of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
