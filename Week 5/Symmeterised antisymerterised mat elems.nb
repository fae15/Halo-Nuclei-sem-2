Cell[TextData[{
 "This verifies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["O", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], 
             StyleBox["i", "TI"]}]], "\[LongEqual]", "1"}], TraditionalForm], 
      "errors" -> {}, "input" -> "O_{ii}=1", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "c2767b97-5d23-2d4c-9ba7-c614591d2db9"],
 ", so we have normalised states. We now need to consider the overlaps of \
different states, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LeftAngleBracket]", 
         RowBox[{" ", 
           StyleBox["i", "TI"], ",", 
           StyleBox["j", "TI"], "|", 
           StyleBox["k", "TI"], ",", 
           StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i, j|k, l\\ \\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "37e67307-b587-5c43-a513-bf276ac7368c"],
 ". Using the above we can write this as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], ",", 
            StyleBox["l", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\langle\\ i, j|k, l\\ \\rangle=O_{ik}O_{j,l}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a687188b-88a8-7542-885b-f0f0e8153714"],
 ", as these are separable we only need to find the expression for one as."
}], "Text",
 CellChangeTimes->{{3.981090676153673*^9, 3.981090679115629*^9}, {
  3.981090724913431*^9, 3.9810908040299206`*^9}, {3.981090839611059*^9, 
  3.9810908966539383`*^9}},ExpressionUUID->"2be514bf-2291-1541-9a67-\
952ac08940c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"PowerExpand", "[", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"UnNormalisedGaussianWavefunc", "[", 
      RowBox[{"r", ",", " ", "\[Alpha]i"}], "]"}], 
     RowBox[{"UnNormalisedGaussianWavefunc", "[", 
      RowBox[{"r", ",", " ", "\[Alpha]k"}], "]"}], 
     SuperscriptBox["r", "2"], 
     RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", " ", "0", ",", " ", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{
      RowBox[{"\[Alpha]i", ">", "0"}], "\[And]", 
      RowBox[{"\[Alpha]k", ">", "0"}]}]}]}], "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Normalisation", "[", "\[Alpha]i", "]"}], 
  RowBox[{"Normalisation", "[", "\[Alpha]k", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"PowerExpand", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"UnNormalisedGaussianWavefunc", "[", 
       RowBox[{"r", ",", " ", "\[Alpha]i"}], "]"}], 
      RowBox[{"UnNormalisedGaussianWavefunc", "[", 
       RowBox[{"r", ",", " ", "\[Alpha]k"}], "]"}], 
      SuperscriptBox["r", "2"], 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", " ", "0", ",", " ", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{
       RowBox[{"\[Alpha]i", ">", "0"}], "\[And]", 
       RowBox[{"\[Alpha]k", ">", "0"}]}]}]}], "]"}], 
   RowBox[{"Normalisation", "[", "\[Alpha]i", "]"}], 
   RowBox[{"Normalisation", "[", "\[Alpha]k", "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.981090685728674*^9, 3.981090695460003*^9}, {
  3.981090904399805*^9, 3.9810909045836735`*^9}},
 CellLabel->"In[50]:=",ExpressionUUID->"19c8ebe8-af0b-ba40-b805-df58831fd6c4"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[Pi]", 
   RowBox[{"3", "/", "2"}]], 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["\[Alpha]i", "2"]], "+", 
     FractionBox["1", 
      SuperscriptBox["\[Alpha]k", "2"]]}], ")"}], 
   RowBox[{"3", "/", "2"}]]]], "Output",
 CellChangeTimes->{3.9810906970536823`*^9, 3.981090906782961*^9},
 CellLabel->"Out[50]=",ExpressionUUID->"db1449e3-bce9-cb4a-9f92-8c2956f50e6b"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SqrtBox["2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox["1", 
      SuperscriptBox["\[Alpha]i", "2"]], ")"}], 
    RowBox[{"3", "/", "4"}]], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox["1", 
      SuperscriptBox["\[Alpha]k", "2"]], ")"}], 
    RowBox[{"3", "/", "4"}]]}], 
  SuperscriptBox["\[Pi]", 
   RowBox[{"3", "/", "2"}]]]], "Output",
 CellChangeTimes->{3.9810906970536823`*^9, 3.981090906783966*^9},
 CellLabel->"Out[51]=",ExpressionUUID->"f51fe69a-cbaa-5d47-8db0-d34a3fe68c8e"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SqrtBox["2"]}], 
  RowBox[{
   SuperscriptBox["\[Alpha]i", 
    RowBox[{"3", "/", "2"}]], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Alpha]i", "2"]], "+", 
      FractionBox["1", 
       SuperscriptBox["\[Alpha]k", "2"]]}], ")"}], 
    RowBox[{"3", "/", "2"}]], " ", 
   SuperscriptBox["\[Alpha]k", 
    RowBox[{"3", "/", "2"}]]}]]], "Output",
 CellChangeTimes->{3.9810906970536823`*^9, 3.9810909072314663`*^9},
 CellLabel->"Out[52]=",ExpressionUUID->"e2572193-605f-4746-814c-5b03637e85d7"]
}, Open  ]],

Cell[TextData[{
 "Thus we  find ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", 
