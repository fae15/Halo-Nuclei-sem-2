                 FractionBox["1", 
                  SubsuperscriptBox["\[Alpha]", 
                   StyleBox["k", "TI"], "2"]]}], ")"}], 
             RowBox[{"3", "/", "2"}]]}]], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
