Notebook[{
Cell[TextData[{
 "We want to be extra careful with getting the correct matrix elements. Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          RowBox[{"\[LeftAngleBracket]", 
            RowBox[{
              SubscriptBox[
               OverscriptBox[
                StyleBox["r", "TI"], "\[RightVector]"], "1"], ",", 
              SubscriptBox[
               OverscriptBox[
                StyleBox["r", "TI"], "\[RightVector]"], "2"], "|", 
              StyleBox["i", "TI"], ",", 
              StyleBox["j", "TI"], " "}], "\[RightAngleBracket]"}], 
          "\[LongEqual]", 
          SubscriptBox["\[CapitalPhi]", 
           StyleBox["i", "TI"]], 
          RowBox[{"(", 
            SubscriptBox[
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
          SubscriptBox["\[CapitalPhi]", 
           StyleBox["j", "TI"]], 
          RowBox[{"(", 
            SubscriptBox[
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}]}], 
        TraditionalForm], "errors" -> {}, "input" -> 
      "\\langle \\vec{r}_{1}, \\vec{r}_{2}|i,j\\ \
\\rangle=\\Phi_{i}(\\vec{r}_{1})\\Phi_{j}(\\vec{r}_{2})", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "11f894a7-11e8-f54f-897e-1548387db364"],
 " be our symmetric particle wavefunction. Still staying in the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["l", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "l=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2af3e691-b075-d040-89cc-bcfae84764db"],
 " case we write ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["l", "TI"]], 
         RowBox[{"(", 
           SubscriptBox[
            OverscriptBox[
             StyleBox["r", "TI"], "\[RightVector]"], 
            StyleBox["i", "TI"]], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["l", "TI"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SubsuperscriptBox[
             StyleBox["r", "TI"], 
             StyleBox["i", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["l", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\Phi_{l}(\\vec{r}_{i}) = N_{l}e^{-r_{i}^{2}/\\alpha_{l}^{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "258f83ea-ee6a-7740-a559-32a0578a7f56"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox[
         StyleBox["N", "TI"], 
         StyleBox["l", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
      "N_{l}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "24b1b03e-dbaf-f64f-8176-dc9f377613a8"],
 "is some normalisation. Since the basis is separable we chose our \
normalisation such that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], "|", 
             StyleBox["i", "TI"], " "}], "\[RightAngleBracket]"}], 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["j", "TI"], "|", 
             StyleBox["j", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["i", "TI"]}]], 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", "1*1", "\[LongEqual]", 
         "1"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i,j|i,j\\ \\rangle=\\langle\\ i|i\\ \\rangle\\langle\\ j|j\\ \
\\rangle = O_{ii}O_{jj}=1 * 1=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "69f74870-b4a7-b643-a8e6-62c998679d48"],
 ". "
}], "Text",
 CellChangeTimes->{{3.9809360821914654`*^9, 3.9809361389092026`*^9}, {
  3.9809361725966244`*^9, 3.980936193308096*^9}, {3.9809363471687527`*^9, 
  3.9809363935292473`*^9}, {3.9809364531128597`*^9, 3.980936485305174*^9}, {
  3.9809365399289436`*^9, 3.9809365627606907`*^9}, {3.980936679075596*^9, 
  3.9809366930686836`*^9}},ExpressionUUID->"9a4c4b91-8125-4c4b-a794-\
aae5e23658db"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"UnNormalisedGaussianWavefunc", "[", 
   RowBox[{"r_", ",", " ", "\[Alpha]i_"}], "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["r", "2"]}], "/", 
    SuperscriptBox["\[Alpha]i", "2"]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"UnNormalisedGaussianWavefunc", "[", 
     RowBox[{"r", ",", " ", "\[Alpha]"}], "]"}], " ", 
    RowBox[{"UnNormalisedGaussianWavefunc", "[", 
     RowBox[{"r", ",", " ", "\[Alpha]"}], "]"}], 
    SuperscriptBox["r", "2"], 
    RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", " ", "0", ",", " ", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"\[Alpha]", ">", "0"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.980936808031908*^9, 3.9809369620443726`*^9}, {
  3.980936995354841*^9, 3.980936995586668*^9}, {3.9809370402616653`*^9, 
  3.980937089103071*^9}, {3.9809377374238377`*^9, 3.9809377418018723`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"4cd6f94e-6751-2d42-9674-6ccdf1a58247"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  SqrtBox[
   FractionBox["\[Pi]", "2"]], " ", "\[Pi]", " ", 
  SuperscriptBox["\[Alpha]", "3"]}]], "Output",
 CellChangeTimes->{3.9809369982572155`*^9, 3.9809370913919353`*^9, 
  3.980937744111124*^9, 3.981088253602846*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"79101f5f-36b9-1f46-b3bd-2ea6974fa114"]
}, Open  ]],

Cell[TextData[{
 "So setting ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         RowBox[{"(", 
           FractionBox[
            SuperscriptBox["2", 
             RowBox[{"3", "/", "4"}]], 
            RowBox[{
              SuperscriptBox["\[Pi]", 
               RowBox[{"3", "/", "4"}]], 
              SuperscriptBox["\[Alpha]", 
               RowBox[{"3", "/", "2"}]]}]], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "N_{i}=\\left(\\frac{2^{3/4}}{\\pi^{3/4}\\alpha^{3/2}}\\right)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c0895096-2ce0-684d-a870-e8db5428c458"],
 " gives  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["i", "TI"]}]], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "O_{ii}=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "781a205e-adaf-2a43-9382-cf2b250ceaea"],
 ", which is slightly different from the previous normalisation since we do \
not assume that we have a spherical harmonic this time (since we no longer \
have a central potential). From this we define our normalised states"
}], "Text",
 CellChangeTimes->{{3.9809371004797497`*^9, 3.980937103430195*^9}, {
  3.980937137307707*^9, 3.9809371801989517`*^9}, {3.9809372512278366`*^9, 
  3.980937320885769*^9}, {3.9809373741415024`*^9, 3.9809374017309303`*^9}, {
  3.9809375254755173`*^9, 3.98093752687994*^9}, {3.9809377641587944`*^9, 
  3.980937770403944*^9}, {3.9809378240935287`*^9, 
  3.980937847718216*^9}},ExpressionUUID->"304e4d46-0c29-b04a-8497-\
a5ec20398f25"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"NormalisedGaussianWavefunction", "[", 
   RowBox[{"r_", ",", " ", "\[Alpha]_"}], "]"}], ":=", " ", 
  RowBox[{
   RowBox[{"(", 
    FractionBox[
     RadicalBox[
      SuperscriptBox["2", "3"], "4",
      MultilineFunction->None,
      SurdForm->True], 
     RowBox[{
      SuperscriptBox["\[Pi]", "0.75"], 
      SuperscriptBox["\[Alpha]", 
       RowBox[{"3", "/", "2"}]]}]], ")"}], 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["r", "2"]}], "/", 
     SuperscriptBox["\[Alpha]", "2"]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Normalisation", "[", "\[Alpha]_", "]"}], ":=", 
  SuperscriptBox[
   RowBox[{"(", 
    FractionBox["2", 
     RowBox[{"\[Pi]", " ", 
      SuperscriptBox["\[Alpha]", "2"]}]], ")"}], 
   RowBox[{"3", "/", "4"}]]}]}], "Input",
 CellChangeTimes->{{3.9809378735635395`*^9, 3.980937919145235*^9}, {
  3.9809379642191544`*^9, 3.9809380126629543`*^9}, {3.9809381066626015`*^9, 
  3.9809381361647778`*^9}, {3.9809383528040733`*^9, 3.980938373857033*^9}, {
  3.980938707988516*^9, 3.98093875576437*^9}, {3.980938817624029*^9, 
  3.9809388335522327`*^9}, {3.981088431456808*^9, 3.9810884708228455`*^9}, {
  3.981088643914345*^9, 3.9810886457717686`*^9}, {3.981089493889681*^9, 
  3.9810894991916714`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"a400e9a3-90ef-8241-bc93-e09c0c697abb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"NormalisedGaussianWavefunction", "[", 
     RowBox[{"r", ",", " ", "\[Alpha]"}], "]"}], 
    RowBox[{"NormalisedGaussianWavefunction", "[", 
     RowBox[{"r", ",", " ", "\[Alpha]"}], "]"}], 
    SuperscriptBox["r", "2"], 
    RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", " ", "0", ",", " ", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"\[Alpha]", ">", "0"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9809380214236355`*^9, 3.9809380978175793`*^9}, {
  3.9809383186463585`*^9, 3.9809383379852295`*^9}, {3.9809383838729496`*^9, 
  3.980938398287943*^9}, {3.9809384493854103`*^9, 3.9809384616991787`*^9}, {
  3.98093881305966*^9, 3.9809388775716*^9}, {3.981088235740778*^9, 
  3.981088244458639*^9}, {3.9810890644749146`*^9, 3.981089087044548*^9}, {
  3.981090188174427*^9, 3.9810902395171127`*^9}, {3.981090668464859*^9, 
  3.981090669235302*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"3c798d16-b11e-4543-9aad-82ab683bcb6c"],

Cell[BoxData["0.9999999999999997`"], "Output",
 CellChangeTimes->{{3.9809380932398777`*^9, 3.980938141877344*^9}, {
   3.980938339483204*^9, 3.980938400782482*^9}, {3.9809384527936726`*^9, 
   3.980938464266958*^9}, 3.9809387587721195`*^9, {3.9809388574378815`*^9, 
   3.9809388792369175`*^9}, 3.9810882543834515`*^9, 3.981088479005268*^9, 
   3.9810886516389885`*^9, {3.9810890696845684`*^9, 3.981089089667055*^9}, 
   3.9810895037320023`*^9, {3.9810901909641876`*^9, 3.9810902403243847`*^9}, 
