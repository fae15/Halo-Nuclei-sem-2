          StyleBox["k", "TI"]], 
         RowBox[{"(", 
           SubscriptBox[
            OverscriptBox[
             StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i,j|\\hat{T}_{1}|k,l\\ \\rangle=T_{ik}O_{jl},\\ \
T_{ik}=\\frac{h^{2}}{8\\pi^{2}\\mu}\\int \
d^{3}\\vec{r}_{1}\\Phi_{i}(\\vec{r}_{1})\\nabla^{2}\\Phi_{k}(\\vec{r}_{1})", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6072eddc-111d-4442-a0a8-f2351b14e47e"],
 ". Taking ",
