alpha_{l}^{2}\\right)}\\right)^{3/2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d90e65d5-a11a-1d42-bab6-95a6cd8277e0"],
 ".\n",
 StyleBox["Kinetic Matrix Elements",
  FontWeight->"Bold"],
 "\nNext we want to consider our Kinetic matrix elements. For the S wave \
state we have l=0 and the kinetic operator becomes ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
