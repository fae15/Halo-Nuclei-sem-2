    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1e2362d9-bbdb-b64c-90e7-dd5c8d64edb4"],
 " for the integral over the radial terms, we have \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", "-", 
         FractionBox[
