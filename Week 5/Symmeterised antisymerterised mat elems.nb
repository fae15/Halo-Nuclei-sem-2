                 StyleBox["u", "TI"], 
                 StyleBox["k", "TI"]], 
                RowBox[{"(", 
                  StyleBox["r", "TI"], ")"}]}], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]], "-", 
             SubscriptBox[
              StyleBox["u", "TI"], 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"], 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["u", "TI"], 
             StyleBox["i", "TI"]], "(", 
            StyleBox["r", "TI"], ")"}], 
          StyleBox["r", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              RowBox[{
                StyleBox["d", "TI"], 
                SubscriptBox[
                 StyleBox["u", "TI"], 
                 StyleBox["k", "TI"]], 
                RowBox[{"(", 
                  StyleBox["r", "TI"], ")"}]}], 
              RowBox[{
