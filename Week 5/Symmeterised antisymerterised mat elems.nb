             SubsuperscriptBox[
              StyleBox["V", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["l", "TI"]}], "cn"], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]], "-", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], 
