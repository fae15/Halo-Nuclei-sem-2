              RowBox[{"\[PartialD]", 
                StyleBox["r", "TI"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\nabla^{2}=\\frac{1}{r^{2}}\\frac{\\partial}{\\partial \
r}\\left(r^{2}\\frac{\\partial}{\\partial r}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a85ceedf-a190-f34f-93e0-ed2a51d82b4c"],
 ". Since this expression involves a second derivative it is awkward to \
evaluate, however there is a way to simplify using integration by parts. We \
start with the matrix element for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["T", "TI"], "^"], "1"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\hat{T}_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "41a76de9-28a5-454f-9b50-e37399a0fc7b"],
 ", which can be extended to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["T", "TI"], "^"], "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\hat{T}_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f3d9eda9-813f-c34e-9a76-aa06aa0e532a"],
 " by symmetry. ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
