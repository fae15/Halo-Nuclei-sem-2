          RowBox[{"3", "/", "2"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "O_{ik}=\\frac{2\\sqrt{2}}{(\\alpha_{i}\\alpha_{k})^{3/2}\\left(\\frac{1}\
{\\alpha_{i}^{2}}+\\frac{1}{\\alpha_{k}^{2}}\\right)^{3/2}}=\\left(\\frac{2\\\
alpha_{i}\\alpha_{k}}{\\alpha_{i}^{2}+\\alpha_{k}^{2}}\\right)^{3/2}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5170dd56-8c86-a04e-a4f9-dc0e9a3b9c47"],
 ". If we define ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
