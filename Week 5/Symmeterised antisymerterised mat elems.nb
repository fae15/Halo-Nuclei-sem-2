             RowBox[{"(", 
               StyleBox["r", "TI"], ")"}]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "T_{ij}=-\\frac{h^{2}}{2\\pi\\mu}\\int_{0}^{\\infty}dr \
