                  StyleBox["r", "TI"], ")"}]}], 
              RowBox[{
                StyleBox["d", "TI"], 
                SuperscriptBox[
                 StyleBox["r", "TI"], "2"]}]], "-", 
             FractionBox[
              RowBox[{
                StyleBox["d", "TI"], 
                SubscriptBox[
                 StyleBox["u", "TI"], 
                 StyleBox["k", "TI"]], 
                RowBox[{"(", 
                  StyleBox["r", "TI"], ")"}]}], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]]}], ")"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"], 
         SubscriptBox[
          StyleBox["u", "TI"], 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["d", "TI"], "2"], 
            SubscriptBox[
             StyleBox["u", "TI"], 
             StyleBox["k", "TI"]], 
            RowBox[{"(", 
              StyleBox["r", "TI"], ")"}]}], 
          RowBox[{
            StyleBox["d", "TI"], 
