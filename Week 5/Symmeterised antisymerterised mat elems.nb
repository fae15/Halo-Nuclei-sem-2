         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], 
             SubscriptBox[
              StyleBox["T", "TI"], 
