il}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f65babf2-b2af-cc48-acdf-f9a79d9e0e7b"],
 "\n\nFor the the neutron-neutron potential matrix element we have \n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SuperscriptBox[
              OverscriptBox[
               StyleBox["V", "TI"], "^"], 
              RowBox[{
                StyleBox["n", "TI"], 
                StyleBox["n", "TI"]}]], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
