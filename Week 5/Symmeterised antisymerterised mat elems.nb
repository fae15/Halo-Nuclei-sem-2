     "input" -> "\\Phi(r)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "75ab2506-738e-c146-a5f7-ecf41d1e1ec9"],
 " and putting the constants back in we obtain for the kinetic matrix element \
\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], "\[LongEqual]", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"2", "\[Pi]\[Mu]"}]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              StyleBox["d", "TI"], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]], 
             RowBox[{"[", 
               RowBox[{
                 StyleBox["r", "TI"], 
                 SubscriptBox["\[CapitalPhi]", 
                  StyleBox["i", "TI"]], 
                 RowBox[{"(", 
                   StyleBox["r", "TI"], ")"}]}], "]"}]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              StyleBox["d", "TI"], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["r", "TI"]}]], 
             RowBox[{"[", 
               RowBox[{
                 StyleBox["r", "TI"], 
                 SubscriptBox["\[CapitalPhi]", 
                  StyleBox["k", "TI"]], 
                 RowBox[{"(", 
                   StyleBox["r", "TI"], ")"}]}], "]"}]}], ")"}], 
         StyleBox["d", "TI"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "T_{ik}=-\\frac{h^{2}}{2\\pi\\mu}\\int_{0}^{\\infty}\\left(\\frac{d}{dr}\
\\left [r\\Phi_{i}(r)\\right]\\right)\\left(\\frac{d}{dr}\\left[ \
r\\Phi_{k}(r)\\right]\\right) dr", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d57b5add-643a-7d4c-b008-67dc8b84c529"],
 ".\nWe now evaluate this by"
}], "Text",
 CellChangeTimes->{{3.9810890163679447`*^9, 3.9810890486152954`*^9}, {
   3.981089838752159*^9, 3.981089867757511*^9}, {3.981090454784342*^9, 
   3.981090456672058*^9}, 3.9810905268653584`*^9, {3.981090585590807*^9, 
   3.98109065103026*^9}, {3.981090709998768*^9, 3.9810907124616356`*^9}, {
   3.981090911732462*^9, 3.981090922429926*^9}, {3.981091404087364*^9, 
   3.9810914381433525`*^9}, {3.9810914890043144`*^9, 3.981091531014292*^9}, {
   3.9810916272218876`*^9, 3.981091670264433*^9}, {3.9810917453193016`*^9, 
   3.981091854851097*^9}, {3.9810919118659496`*^9, 3.9810920656817513`*^9}, 
   3.981092122206341*^9, {3.9810923982862473`*^9, 3.9810924773115864`*^9}, {
   3.9810926478415794`*^9, 3.981092648051256*^9}, {3.981092686383415*^9, 
   3.9810926906579895`*^9}, {3.981096293682211*^9, 3.981096381302164*^9}, 
   3.9810964218521957`*^9, {3.981096752103882*^9, 3.9810968095921097`*^9}, {
   3.981096848419241*^9, 3.981096905254532*^9}, {3.9810970389393673`*^9, 
   3.9810970748831387`*^9}, {3.9810972212097282`*^9, 3.981097235011156*^9}, {
   3.981097368807743*^9, 3.981097386225281*^9}, {3.9815279959181576`*^9, 
   3.981528002790127*^9}},ExpressionUUID->"30cfda1e-3aa0-1f45-8e63-\
58f679064691"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PowerExpand", "[", 
  RowBox[{
   FractionBox[
    SuperscriptBox["\[HBar]", "2"], 
    RowBox[{"2", "\[Mu]"}]], 
   RowBox[{"Normalisation", "[", "\[Alpha]i", "]"}], 
   RowBox[{"Normalisation", "[", "\[Alpha]k", "]"}], 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"UnNormalisedGaussianWavefunc", "[", 
          RowBox[{"r", ",", " ", "\[Alpha]i"}], "]"}], "r"}], ",", "r"}], 
       "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"UnNormalisedGaussianWavefunc", "[", 
          RowBox[{"r", ",", " ", "\[Alpha]k"}], "]"}], "r"}], ",", " ", "r"}],
        "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", " ", "0", ",", " ", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{
       RowBox[{"\[Alpha]i", ">", "0"}], " ", "\[And]", 
       RowBox[{"\[Alpha]k", ">", "0"}]}]}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981095502726721*^9, 3.981095506506668*^9}, {
  3.981095742381914*^9, 3.981095787260069*^9}, {3.981096236119051*^9, 
  3.981096264693304*^9}},
 CellLabel->"In[66]:=",ExpressionUUID->"eac9ddd0-2fe0-444a-92e4-f16d64d46c08"],

Cell[BoxData[
 FractionBox[
  RowBox[{"6", " ", 
   SqrtBox["2"], " ", 
   SuperscriptBox["\[Alpha]i", 
    RowBox[{"3", "/", "2"}]], " ", 
   SuperscriptBox["\[Alpha]k", 
    RowBox[{"3", "/", "2"}]], " ", 
   SuperscriptBox["\[HBar]", "2"]}], 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Alpha]i", "2"], "+", 
      SuperscriptBox["\[Alpha]k", "2"]}], ")"}], 
    RowBox[{"5", "/", "2"}]], " ", "\[Mu]"}]]], "Output",
 CellChangeTimes->{
  3.9810955112054863`*^9, 3.981095747413233*^9, {3.9810957791836605`*^9, 
   3.9810957881010494`*^9}, 3.981096271011532*^9},
 CellLabel->"Out[66]=",ExpressionUUID->"4d782edc-9715-1945-8c0d-f0a1cafd00ae"]
}, Open  ]],

Cell[TextData[{
 "Hence we find ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"3", 
            SuperscriptBox[
             StyleBox["h", "TI"], "2"]}], 
          RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"2", "\[Pi]"}], ")"}], "2"], "\[Mu]"}]], 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{"2", 
               SubscriptBox["\[Alpha]", 
                StyleBox["i", "TI"]], 
               SubscriptBox["\[Alpha]", 
                StyleBox["k", "TI"]]}], ")"}], 
           RowBox[{"3", "/", "2"}]], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["i", "TI"], "2"], "+", 
               SubsuperscriptBox["\[Alpha]", 
                StyleBox["k", "TI"], "2"]}], ")"}], 
           RowBox[{"5", "/", "2"}]]], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             StyleBox["h", "TI"], 
             RowBox[{"2", "\[Pi]"}]], ")"}], "2"], 
         FractionBox["1", 
          RowBox[{"2", "\[Mu]"}]], 
         FractionBox["6", 
          RowBox[{
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["i", "TI"], "2"], "+", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["k", "TI"], "2"]}]], 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "T_{ij}=\\frac{3h^{2}}{\\left(2\\pi\\right)^{2}\\mu}\\frac{\\left(2\\\
alpha_{i}\\alpha_{k}\\right)^{3/2}}{\\left(\\alpha_{i}^{2}+\\alpha_{k}^{2}\\\
right)^{5/2}} = \\left(\\frac{h}{2\\pi}\\right)^{2}\\frac{1}{2\\mu}\\frac{6}{\
\\alpha_{i}^{2}+\\alpha_{k}^{2}}O_{ik}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a92d00a3-6550-514d-90bc-332eaeba60e1"],
 ". \n",
 StyleBox["Potential Matrix elements",
  FontWeight->"Bold"],
 "\nFor a core-neutron gaussian potential of the form ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["V", "TI"], "cn"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["r", "TI"], 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["V", "TI"], "0"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", "\[Beta]", 
            SubsuperscriptBox[
             StyleBox["r", "TI"], 
             StyleBox["n", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "V^{\\text{cn}}(r_{n})=V_{0}e^{-\\beta r_{n}^{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1d532290-2b9c-7644-977d-d8e09f2b2c95"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["V", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "V_{0}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "26e67b69-76b1-824e-90a5-09f2eec14e70"],
 " is the depth of the potential and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Beta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1cfd6fd8-2eb5-6641-b169-b8236ebca48f"],
 " parameterizes the width of the potential. The matrix elements, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["V", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["k", "TI"]}], "cn"], TraditionalForm], "errors" -> {}, 
     "input" -> "V_{ik}^{\\text{cn}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f7f53cb-9934-5147-8987-96dc9fb07af2"],
 ", are found by"
}], "Text",
 CellChangeTimes->{{3.9810974531842213`*^9, 3.981097454246483*^9}, {
   3.981097487179695*^9, 3.9810974937855797`*^9}, 3.9810977268059845`*^9, {
   3.9811038664018745`*^9, 3.981103866828619*^9}, {3.9811039626042233`*^9, 
   3.9811039641558666`*^9}, {3.9811040194881916`*^9, 
   3.9811040202540226`*^9}, {3.981104057099825*^9, 3.9811040728517494`*^9}, {
   3.981104201443821*^9, 3.981104302819048*^9}, {3.9815280223584366`*^9, 
   3.981528030512722*^9}},ExpressionUUID->"ee9b1e38-c932-1f46-8b4f-\
137ca65cd0b6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GaussianPotential", "[", 
   RowBox[{"r_", ",", " ", "\[Beta]_", ",", " ", "V0_"}], "]"}], ":=", 
  RowBox[{"V0", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "\[Beta]"}], " ", 
     SuperscriptBox["r", "2"]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"PowerExpand", "[", 
  RowBox[{
   RowBox[{"Normalisation", "[", "\[Alpha]i", "]"}], 
   RowBox[{"Normalisation", "[", "\[Alpha]k", "]"}], 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"UnNormalisedGaussianWavefunc", "[", 
       RowBox[{"r", ",", " ", "\[Alpha]i"}], "]"}], 
      RowBox[{"GaussianPotential", "[", 
       RowBox[{"r", ",", " ", "\[Beta]", ",", " ", "V0"}], "]"}], 
      RowBox[{"UnNormalisedGaussianWavefunc", "[", 
       RowBox[{"r", ",", " ", "\[Alpha]k"}], "]"}], 
      SuperscriptBox["r", "2"], 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", " ", "0", ",", " ", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{
       RowBox[{"\[Alpha]i", ">", "0"}], "\[And]", 
       RowBox[{"\[Alpha]k", ">", "0"}], "\[And]", 
       RowBox[{"\[Beta]", ">", "0"}]}]}]}], "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.981104307150503*^9, 3.9811044740885887`*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"228140e9-30d9-e743-870c-af8094a8c9d7"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SqrtBox["2"], " ", "V0"}], 
  RowBox[{
   SuperscriptBox["\[Alpha]i", 
    RowBox[{"3", "/", "2"}]], " ", 
   SuperscriptBox["\[Alpha]k", 
    RowBox[{"3", "/", "2"}]], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Alpha]i", "2"]], "+", 
      FractionBox["1", 
       SuperscriptBox["\[Alpha]k", "2"]], "+", "\[Beta]"}], ")"}], 
    RowBox[{"3", "/", "2"}]]}]]], "Output",
 CellChangeTimes->{{3.981104462988613*^9, 3.9811044757760143`*^9}},
 CellLabel->"Out[70]=",ExpressionUUID->"5673abb9-c5fe-454e-b4e7-b9f835d4047e"]
}, Open  ]],

Cell[TextData[{
 "So the matrix element is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}], "cn"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["V", "TI"], "0"], 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox["2", 
             RowBox[{
               SubscriptBox["\[Alpha]", 
                StyleBox["i", "TI"]], 
               SubscriptBox["\[Alpha]", 
                StyleBox["k", "TI"]], 
               RowBox[{"(", 
                 RowBox[{
                   FractionBox["1", 
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["i", "TI"], "2"]], "+", 
                   FractionBox["1", 
                    SubsuperscriptBox["\[Alpha]", 
                    StyleBox["k", "TI"], "2"]], "+", "\[Beta]"}], ")"}]}]], 
            ")"}], 
          RowBox[{"3", "/", "2"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "V_{ik}^{\\text{cn}}=V_{0}\\left(\\frac{2}{\\alpha_{i}\\alpha_{k}\\left(\
\\frac{1}{\\alpha_{i}^{2}}+\\frac{1}{\\alpha_{k}^{2}}+\\beta\\right)}\\right)^\
{3/2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "172c2438-34b3-8343-ae45-df57c48122c8"],
 ". \nThe total Hamiltonian can be written ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["H", "TI"], "^"], "\[LongEqual]", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["h", "TI"], "^"], "1"], "+", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["h", "TI"], "^"], "2"], "+", 
         SuperscriptBox[
          StyleBox["V", "TI"], "12"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\hat{H}=\\hat{h}_{1}+\\hat{h}_{2}+V^{\\text{12}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "88553201-2c12-fa45-a613-3ea0e1d1c451"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["h", "TI"], "^"], 
        StyleBox["n", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "\\hat{h}_{n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e3c5e7b3-242e-3246-bcdd-8ad520a12efd"],
 " is the Hamiltonian of the nth particle, and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["V", "TI"], "12"], TraditionalForm], "errors" -> {}, "input" -> 
     "V^{\\text{12}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "af92c5fa-4ae2-bb45-9f3f-ac597f8c4e88"],
 " is the two body interaction. The matrix elements of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        OverscriptBox[
         StyleBox["H", "TI"], "^"], TraditionalForm], "errors" -> {}, "input" -> 
      "\\hat{H}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "c139a451-d989-c04e-b0e4-36de2b6fe491"],
 "can be written ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             OverscriptBox[
              StyleBox["H", "TI"], "^"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["T", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], "+", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}], "cn"]}], ")"}], 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], ",", 
            StyleBox["l", "TI"]}]], "+", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], ",", 
            StyleBox["k", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["T", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["l", "TI"]}]], "+", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["l", "TI"]}], "cn"]}], ")"}], "+", 
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["l", "TI"], 
            StyleBox["k", "TI"]}], "12"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\langle\\ i, j|\\hat{H}|k, l\\ \
\\rangle=\\left(T_{ik}+V_{ik}^{{\\text{cn}}\\right)O_{j,l}+O_{i,k}\\left(T_{\
jl}+V_{jl}^{{\\text{cn}}\\right)+V_{ijlk}^{\\text{12}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "408d1104-6f02-2048-84e2-b2d8b33281b2"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["V", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"], 
          StyleBox["k", "TI"], 
          StyleBox["l", "TI"]}], "12"], TraditionalForm], "errors" -> {}, 
     "input" -> "V_{ijkl}^{12}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3e549abd-6cce-b94b-acca-2a68697a9341"],
 " is the two body interaction matrix element.\n\n",
 StyleBox["Neutron-Neutron Interaction Elements",
  FontWeight->"Bold"],
 "\nTo evaluate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["V", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"], 
          StyleBox["k", "TI"], 
          StyleBox["l", "TI"]}], 
        RowBox[{
          StyleBox["n", "TI"], 
          StyleBox["n", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "V_{ijkl}^{nn}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ede1435e-cba2-bd47-8a94-c97573b20f6d"],
 " we need to consider the form of  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["V", "TI"], 
        RowBox[{
          StyleBox["n", "TI"], 
          StyleBox["n", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "V^{nn}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9c32fddb-f078-4544-8dbc-17983868608b"],
 ". We start by considering the nucleus to be infinite mass, and use a \
\[OpenCurlyQuote]V\[CloseCurlyQuote] cooridante system, so will depend on the \
relative position of the two bodies. We use a form of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], 
            StyleBox["n", "TI"]}]], "\[LongEqual]", "-", 
         SubscriptBox[
          StyleBox["U", "TI"], "0"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-|", 
            SubscriptBox[
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], "1"], "-", 
            SubscriptBox[
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], "2"], 
            SuperscriptBox["|", "2"], "/", 
            SuperscriptBox["\[Sigma]", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "V^{nn}=-U_{0}e^{-|\\vec{r}_{1}-\\vec{r}_{2}|^{2}/\\sigma^{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "60ceb111-2928-3844-a264-0295ff6c91b8"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["U", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "U_{0}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7b5da413-2ffb-dc40-8d05-79b3e4a67731"],
 " is the depth of the potential and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|
     "boxes" -> FormBox["\[Sigma]", TraditionalForm], "errors" -> {}, "input" -> 
      "\\sigma", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "cad0eb30-61ab-cf49-95ec-0b8433185a7a"],
 "parameterizes the interaction. This can be written in terms of the relative \
angle, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Theta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a5d0109-7c9c-0742-b7cd-4d561ad65a73"],
 ", between the two as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "-", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         SuperscriptBox["|", "2"], "\[LongEqual]", "|", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], 
         SuperscriptBox["|", "2"], "+", "|", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         SuperscriptBox["|", "2"], "-", "2|", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "||", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], "|", "cos", 
         "\[Theta]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "|\\vec{r}_{1}-\\vec{r}_{2}|^{2}=|\\vec{r}_{1}|^{2}+|\\vec{r}_{2}|^{2}-2|\
\\vec{r}_{1}| |\\vec{r}_{2}| \\cos\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9e80174-1425-3842-88df-5ac7ca3ea3f9"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], 
          StyleBox["n", "TI"]], "|", "\[LongEqual]", 
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "|\\vec{r}_{n}|=r_{n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8d5c0623-269d-9d45-8ee0-1363bc3030fb"],
 " , we now consider the calculation of the matrix element,\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SuperscriptBox[
              StyleBox["V", "TI"], 
              RowBox[{
                StyleBox["n", "TI"], 
                StyleBox["n", "TI"]}]], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", "-", 
         SubscriptBox[
          StyleBox["U", "TI"], "0"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["i", "TI"], "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["j", "TI"], "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{
                 SubsuperscriptBox[
                  StyleBox["r", "TI"], "1", "2"], "+", 
                 SubsuperscriptBox[
                  StyleBox["r", "TI"], "2", "2"], "-", "2", 
                 SubscriptBox[
                  StyleBox["r", "TI"], "1"], 
                 SubscriptBox[
                  StyleBox["r", "TI"], "2"], "cos", 
                 RowBox[{"(", "\[Theta]", ")"}]}], ")"}], "2"], "/", 
            SuperscriptBox["\[Sigma]", "2"]}]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["k", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["l", "TI"]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["k", "TI"], "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            SuperscriptBox[
             StyleBox["r", "TI"], "2"], "/", 
            SubsuperscriptBox["\[Alpha]", 
             StyleBox["l", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\langle\\ i, j|V^{nn}|k, l\\ \\rangle=-U_{0}\\int \
d^{3}\\vec{r}_{1}\\int \
d^{3}\\vec{r}_{2}N_{i}N_{j}e^{-r^{2}/\\alpha_{i}^{2}}e^{-r^{2}/\\alpha_{j}^{2}\
}e^{-\\left(r_{1}^{2}+r_{2}^{2}-2r_{1}r_{2}\\cos(\\theta)\\right)^{2}/\\sigma^\
{2}}N_{k}N_{l}e^{-r^{2}/\\alpha_{k}^{2}}e^{-r^{2}/\\alpha_{l}^{2}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7b59b8ac-e14a-c34c-aa7c-0befd053b388"],
 ".\nGrouping the terms relative to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "1"], "and", 
         SubscriptBox[
          StyleBox["r", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "r_{1} \\text{and} r_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ced25c11-9d15-b940-bba5-679e9121da4f"],
 " we get\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SuperscriptBox[
              StyleBox["V", "TI"], 
              RowBox[{
                StyleBox["n", "TI"], 
                StyleBox["n", "TI"]}]], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", "-", 
         SubscriptBox[
          StyleBox["U", "TI"], "0"], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["k", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["l", "TI"]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            RowBox[{"(", 
              RowBox[{
                FractionBox["1", 
                 SubsuperscriptBox["\[Alpha]", 
                  StyleBox["i", "TI"], "2"]], "+", 
                FractionBox["1", 
                 SubsuperscriptBox["\[Alpha]", 
                  StyleBox["k", "TI"], "2"]], "+", 
                FractionBox["1", 
                 SuperscriptBox["\[Sigma]", "2"]]}], ")"}], 
            SubsuperscriptBox[
             StyleBox["r", "TI"], "1", "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            RowBox[{"(", 
              RowBox[{
                FractionBox["1", 
                 SubsuperscriptBox["\[Alpha]", 
                  StyleBox["j", "TI"], "2"]], "+", 
                FractionBox["1", 
                 SubsuperscriptBox["\[Alpha]", 
                  StyleBox["l", "TI"], "2"]], "+", 
                FractionBox["1", 
                 SuperscriptBox["\[Sigma]", "2"]]}], ")"}], 
            SubsuperscriptBox[
             StyleBox["r", "TI"], "2", "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"2", 
            SubscriptBox[
             StyleBox["r", "TI"], "1"], 
            SubscriptBox[
             StyleBox["r", "TI"], "2"], "cos", "\[Theta]", "/", 
            SuperscriptBox["\[Sigma]", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\langle\\ i, j|V^{nn}|k, l\\ \\rangle=-U_{0}N_{i}N_{j}N_{k}N_{l}\\int \
d^{3}\\vec{r}_{1}\\int \
d^{3}\\vec{r}_{2}e^{-\\left(\\frac{1}{\\alpha_{i}^{2}}+\\frac{1}{\\alpha_{k}^{\
2}}+\\frac{1}{\\sigma^{2}}\\right)r_{1}^{2}}e^{-\\left(\\frac{1}{\\alpha_{j}^{\
2}}+\\frac{1}{\\alpha_{l}^{2}}+\\frac{1}{\\sigma^{2}}\\right)r_{2}^{2}}e^{2r_{\
1}r_{2}\\cos\\theta/\\sigma^{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91e46ba6-6ca1-3749-bc26-b2a1c6f6e7ef"],
 ".\n\nDenoting ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["1", 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["i", "TI"], "2"]], "+", 
         FractionBox["1", 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["k", "TI"], "2"]], "+", 
         FractionBox["1", 
          SuperscriptBox["\[Sigma]", "2"]], "\[LongEqual]", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{1}{\\alpha_{i}^{2}}+\\frac{1}{\\alpha_{k}^{2}}+\\frac{1}{\\sigma^\
{2}}=A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "be9d28c4-342e-094e-a98b-cd2a8f2e4d77"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["1", 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["j", "TI"], "2"]], "+", 
         FractionBox["1", 
          SubsuperscriptBox["\[Alpha]", 
           StyleBox["l", "TI"], "2"]], "+", 
         FractionBox["1", 
          SuperscriptBox["\[Sigma]", "2"]], "\[LongEqual]", 
         StyleBox["B", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{1}{\\alpha_{j}^{2}}+\\frac{1}{\\alpha_{l}^{2}}+\\frac{1}{\\sigma^\
{2}}=B", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7dab3ae0-e278-024a-a9f8-f67e640803ed"],
 ", we fix ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["r", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "r_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "24e9b5b7-df1e-5c45-ac0f-1a475731e5b2"],
 " to be on the z axis, therefore ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", "\[Theta]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\cos\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c45cd812-efbc-504f-91fa-10f531901d89"],
 " specifies ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Theta]", "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\theta_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "da7b658b-8f18-b04f-ad00-34945ca62c5c"],
 ", hence we integrate over ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Theta]", "1"], ",", 
         SubscriptBox["\[Phi]", "1"], ",", 
         SubscriptBox["\[Phi]", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\theta_{1},\\phi_{1}, \\phi_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0fe390b4-1019-6c4c-8d76-14751ca1549f"],
 " which give a contribution of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"8", 
         SuperscriptBox["\[Pi]", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "8\\pi^{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9678fdeb-2f53-0641-accb-deaac48adeea"],
 ", and we are left with \n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-8", 
         SuperscriptBox["\[Pi]", "2"], 
         SubscriptBox[
          StyleBox["U", "TI"], "0"], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["k", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["l", "TI"]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         StyleBox["d", "TI"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         StyleBox["d", "TI"], 
         SubscriptBox[
          StyleBox["r", "TI"], "2"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
         StyleBox["d", "TI"], "\[Theta]", 
         SubsuperscriptBox[
          StyleBox["r", "TI"], "1", "2"], 
         SubsuperscriptBox[
          StyleBox["r", "TI"], "2", "2"], "sin", 
         RowBox[{"(", "\[Theta]", ")"}], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["A", "TI"], 
            SubsuperscriptBox[
             StyleBox["r", "TI"], "1", "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["B", "TI"], 
            SubsuperscriptBox[
             StyleBox["r", "TI"], "2", "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"2", 
            SubscriptBox[
             StyleBox["r", "TI"], "1"], 
            SubscriptBox[
             StyleBox["r", "TI"], "2"], "cos", "\[Theta]", "/", 
            SuperscriptBox["\[Sigma]", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "-8\\pi^{2}U_{0}N_{i}N_{j}N_{k}N_{l}\\int_{0}^{\\infty}dr_{1}\\int_{0}^{\
\\infty} dr_{2}\\int_{0}^{\\pi}d\\theta r_{1}^{2}r_{2}^{2}\\sin(\\theta) \
e^{-Ar_{1}^{2}}e^{-Br_{2}^{2}}e^{2r_{1}r_{2}\\cos\\theta/\\sigma^{2}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f9d291fd-df29-f845-a1ce-81461f7ea55f"],
 ". Integrating over ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Theta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "394da527-872b-2f48-95a3-7dc32fa0309b"],
 " first,"
}], "Text",
 CellChangeTimes->{{3.9811045259452934`*^9, 3.981104530303705*^9}, {
   3.9811046725762386`*^9, 3.9811046884977093`*^9}, {3.981104848794407*^9, 
   3.9811048510692596`*^9}, {3.981104910127077*^9, 3.981104966907772*^9}, {
   3.981105076062334*^9, 3.9811052031710796`*^9}, {3.9811054704107704`*^9, 
   3.9811055074801884`*^9}, {3.9811055603081207`*^9, 
   3.9811056518619595`*^9}, {3.981105692857029*^9, 3.9811057301061096`*^9}, {
   3.9811058202233276`*^9, 3.981105908406698*^9}, {3.9811059964353943`*^9, 
   3.9811060648748684`*^9}, {3.9811062597677784`*^9, 3.981106317561167*^9}, {
   3.981106671551283*^9, 3.9811068275209618`*^9}, {3.9811069554763126`*^9, 
   3.981106959020012*^9}, {3.981107088430828*^9, 3.9811071771514034`*^9}, 
   3.981107216582676*^9, {3.9811073176774235`*^9, 3.981107324526428*^9}, {
   3.9811073619842033`*^9, 3.9811073755635242`*^9}, {3.981528014523081*^9, 
   3.9815280611283607`*^9}, 3.981529814732277*^9, {3.9815407118366165`*^9, 
   3.9815407144281216`*^9}},ExpressionUUID->"5622de8c-a776-da42-a9cd-\
929b83d486c2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Exp", "[", 
      RowBox[{"2", "r1", " ", "r2", " ", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Theta]", "]"}], "/", 
        SuperscriptBox["\[Sigma]", "2"]}]}], "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", " ", "0", ",", " ", "\[Pi]"}], "}"}], ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{
      RowBox[{"\[Sigma]", ">", "0"}], "\[And]", 
      RowBox[{"r1", ">", "0"}], "\[And]", 
      RowBox[{"r2", ">", "0"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.9811058280744*^9, {3.9811073849557686`*^9, 3.9811074893591614`*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"b8cb89a5-68c7-bc44-9d9e-6247e2207a4a"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[Sigma]", "2"], " ", 
   RowBox[{"Sinh", "[", 
    FractionBox[
     RowBox[{"2", " ", "r1", " ", "r2"}], 
     SuperscriptBox["\[Sigma]", "2"]], "]"}]}], 
  RowBox[{"r1", " ", "r2"}]]], "Output",
 CellChangeTimes->{3.981107491463827*^9},
 CellLabel->"Out[71]=",ExpressionUUID->"47edca07-56f9-7449-88d2-cfaed9b558b5"]
}, Open  ]],

Cell[TextData[{
 "So we obtain ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["l", "TI"]}], 
          RowBox[{
            StyleBox["n", "TI"], 
            StyleBox["n", "TI"]}]], "\[LongEqual]", "-8", 
         SuperscriptBox["\[Pi]", "2"], 
         SuperscriptBox["\[Sigma]", "2"], 
         SubscriptBox[
          StyleBox["U", "TI"], "0"], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["i", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["j", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["k", "TI"]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          StyleBox["l", "TI"]], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         StyleBox["d", "TI"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         StyleBox["d", "TI"], 
         SubscriptBox[
          StyleBox["r", "TI"], "2"], 
         SubscriptBox[
          StyleBox["r", "TI"], "1"], 
         SubscriptBox[
          StyleBox["r", "TI"], "2"], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["A", "TI"], 
            SubsuperscriptBox[
             StyleBox["r", "TI"], "1", "2"]}]], 
         SuperscriptBox[
          StyleBox["e", "TI"], 
          RowBox[{"-", 
            StyleBox["B", "TI"], 
            SubsuperscriptBox[
             StyleBox["r", "TI"], "2", "2"]}]], "sinh", 
         RowBox[{"(", 
           FractionBox[
            RowBox[{"2", 
              SubscriptBox[
               StyleBox["r", "TI"], "1"], 
              SubscriptBox[
               StyleBox["r", "TI"], "2"]}], 
            SuperscriptBox["\[Sigma]", "2"]], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "V_{ijkl}^{nn}=-8\\pi^{2}\\sigma^{2}U_{0}N_{i}N_{j}N_{k}N_{l}\\int_{0}^{\
\\infty}dr_{1}\\int_{0}^{\\infty}dr_{2}r_{1}r_{2}e^{-Ar_{1}^{2}}e^{-Br_{2}^{2}\
}\\sinh\\left(\\frac{2r_{1}r_{2}}{\\sigma^{2}}\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a53f3980-5259-7d46-8dc3-7bd6ea29787f"],
 ". Integrating over ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["r", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "r_{1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ab7e1c59-1737-4644-a89d-82d0a585b0e0"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["r", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "r_{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2abf3ddf-b8e1-4245-8ec2-49dfb987420e"],
 " separately "
}], "Text",
 CellChangeTimes->{{3.9811075771011753`*^9, 3.9811075954293976`*^9}, {
  3.9811077136306343`*^9, 3.9811077343072968`*^9}, {3.9811077692827396`*^9, 
  3.9811077903964615`*^9}},ExpressionUUID->"f8909cdb-08c6-8749-857d-\
04be193e57e4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"r1", " ", "r2", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "A"}], " ", 
      RowBox[{"r1", "^", "2"}]}], "]"}], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "B"}], " ", 
      RowBox[{"r2", "^", "2"}]}], "]"}], " ", 
    RowBox[{"Sinh", "[", 
     FractionBox[
      RowBox[{"2", "r1", " ", "r2"}], 
      SuperscriptBox["\[Sigma]", "2"]], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"r1", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"r2", ",", " ", "0", ",", " ", "\[Infinity]"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"A", ">", "0"}], "\[And]", 
     RowBox[{"B", ">", "0"}], "\[And]", " ", 
     RowBox[{"\[Sigma]", ">", "0"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981107793544752*^9, 3.9811079445528336`*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"78d6837b-3c4f-c247-a417-4af95e4daf44"],

Cell[BoxData[
 TemplateBox[{
   FractionBox["\[Pi]", 
    RowBox[{"8", " ", 
      SuperscriptBox["B", 
       RowBox[{"3", "/", "2"}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
         RowBox[{"A", "-", 
           FractionBox["1", 
            RowBox[{"B", " ", 
              SuperscriptBox["\[Sigma]", "4"]}]]}], ")"}], 
       RowBox[{"3", "/", "2"}]], " ", 
      SuperscriptBox["\[Sigma]", "2"]}]], 
   RowBox[{
     RowBox[{"A", " ", "B", " ", 
       SuperscriptBox["\[Sigma]", "4"]}], ">", "1"}]},
  "ConditionalExpression"]], "Output",
 CellChangeTimes->{
  3.981107863980032*^9, {3.981107910670212*^9, 3.981107952302387*^9}},
 CellLabel->"Out[75]=",ExpressionUUID->"55d0ef18-5b02-9440-a27f-2fde839f5b33"]
}, Open  ]],

Cell[TextData[{
 "So the matrix element is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["l", "TI"]}], 
          RowBox[{
            StyleBox["n", "TI"], 
            StyleBox["n", "TI"]}]], "\[LongEqual]", "-", 
         FractionBox[
          RowBox[{
            SuperscriptBox["\[Pi]", "3"], 
            SubscriptBox[
             StyleBox["U", "TI"], "0"], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["i", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["j", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["k", "TI"]], 
            SubscriptBox[
             StyleBox["N", "TI"], 
             StyleBox["l", "TI"]]}], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               StyleBox["A", "TI"], 
               StyleBox["B", "TI"], "-", 
               SuperscriptBox["\[Sigma]", "-4"]}], ")"}], 
           RowBox[{"3", "/", "2"}]]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "V_{ijkl}^{nn}=-\\frac{\\pi^{3}U_{0}N_{i}N_{j}N_{k}N_{l}}{\\left(AB-\\\
sigma^{-4}\\right)^{3/2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2cfe27d7-dd65-3a4f-9c87-21e77591ae8c"]
}], "Text",
 CellChangeTimes->{{3.9811083569853344`*^9, 
  3.9811083744212112`*^9}},ExpressionUUID->"cb53749a-45c5-c741-9941-\
719db6fbf8b6"],

Cell["", "Text",
 CellChangeTimes->{{3.981108840335806*^9, 3.9811088524505806`*^9}, {
   3.9811885204078674`*^9, 3.981188587703924*^9}, 3.981189199033287*^9, 
   3.981194572828287*^9},ExpressionUUID->"caab97f8-a6fd-2849-8cf1-\
b548d3af8736"],

Cell[TextData[{
 "We now want to antisymmetric our wavefunctions. We are in a isospin 1 \
state, which gives a symmetric contribution to the wavefunction \
(unconfirmed). Thus the S=0 state requires a symmetric spatial-wavefunction, \
and the S=1 state requires an antisymmetric spatial-wavefunction. The case \
for the symmetric wavefunction is derived above, we now want to consider the \
antisymmetric spatial-wavefunction. \n\nWe choose a form ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], "|", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"]}], "\[RightAngleBracket]"}], "\[LongEqual]", 
         StyleBox["N", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle \\vec{r}|i, \
j\\rangle=N\\left(\\Phi_{i}(\\vec{r_{1}})\\Phi_{j}(\\vec{r_{2}})-\\Phi_{j}(\\\
vec{r_{1}})\\Phi_{i}(\\vec{r_{2}})\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "733ecabb-8650-9841-972a-86b617001372"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalPhi]", 
          StyleBox["i", "TI"]], "(", 
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["n", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Phi_{i}(r_{n})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c83386c2-56f1-474a-b151-897d7251c75c"],
 " is the normalised wavefunction of the nth particle. The factor ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["N", "TI"], TraditionalForm], "errors" -> {}, "input" -> "N", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a2c7691-46c1-0b4e-b087-e33a70af8e40"],
 " is a normalisation. To find this we consider\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["N", "TI"], "2"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i,j|i, j\\ \\rangle=N^{2}\\int d^{3}\\vec{r}_{1}\\int \
d^{3}\\vec{r}_{2}\\left(\\Phi_{i}(\\vec{r_{1}})\\Phi_{j}(\\vec{r_{2}})-\\Phi_{\
j}(\\vec{r_{1}})\\Phi_{i}(\\vec{r_{2}})\\right)\\left(\\Phi_{i}(\\vec{r_{1}})\
\\Phi_{j}(\\vec{r_{2}})-\\Phi_{j}(\\vec{r_{1}})\\Phi_{i}(\\vec{r_{2}})\\right)\
", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c15d28e-bcd8-8446-842b-6683e8b0158b"],
 "\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SuperscriptBox[
          StyleBox["N", "TI"], "2"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], "-", 
             "2", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], "+", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "1"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               SubscriptBox[
                OverscriptBox[
                 StyleBox["r", "TI"], "\[RightVector]"], "2"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "=N^{2}\\int d^{3}\\vec{r}_{1}\\int \
d^{3}\\vec{r}_{2}\\left(\\Phi_{i}(\\vec{r}_{1})\\Phi_{i}(\\vec{r}_{1})\\Phi_{\
j}(\\vec{r}_{2})\\Phi_{j}(\\vec{r}_{2})-2\\Phi_{i}(\\vec{r}_{1})\\Phi_{j}(\\\
vec{r}_{2})\\Phi_{j}(\\vec{r}_{1})\\Phi_{i}(\\vec{r}_{2})+\\Phi_{j}(\\vec{r}_{\
1})\\Phi_{j}(\\vec{r}_{1})\\Phi_{i}(\\vec{r}_{2})\\Phi_{i}(\\vec{r}_{2})\\\
right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a70c8973-4578-e14f-b62e-01c7abdead1d"],
 "\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SuperscriptBox[
          StyleBox["N", "TI"], "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["i", "TI"]}]], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["j", "TI"]}]], "-", "2", 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["j", "TI"]}]], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["i", "TI"]}]], "+", 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["i", "TI"]}]], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["j", "TI"]}]]}], ")"}], "\[LongEqual]", "2", 
         SuperscriptBox[
          StyleBox["N", "TI"], "2"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             SubsuperscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["j", "TI"]}], "2"]}], ")"}], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "=N^{2}\\left(O_{ii}O_{jj}-2O_{ij}O_{ji}+O_{ii}O_{jj}\\right)=2N^{2}\\\
left(1 - O_{ij}^{2}\\right)=1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1819c85a-ae0c-0f47-b703-02790e1b54a0"],
 ",\n since",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["i", "TI"]}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", "1", "and", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["i", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "O_{ii}=O_{jj}=1 \\text{and} O_{ij}=O_{ji}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fdde6fea-02e9-bb47-bf05-60c127178f43"],
 ", so our normalisation is for our NON-orthogonal basis,\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], "\[LongEqual]", 
         FractionBox["1", 
          SqrtBox[
           RowBox[{"2", "(", 
             RowBox[{"1", "-", 
               SubsuperscriptBox[
                StyleBox["O", "TI"], 
                RowBox[{
                  StyleBox["i", "TI"], 
                  StyleBox["j", "TI"]}], "2"]}], ")"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "N_{ij}=\\frac{1}{\\sqrt{2\\left(1-O_{ij}^{2}\\right)}}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ebc88915-9eae-634c-a53f-c1ebb1c5cb2e"],
 ",\n which for an orthogonal basis gives ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["N", "TI"], "\[LongEqual]", 
         FractionBox["1", 
          SqrtBox["2"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "N=\\frac{1}{\\sqrt{2}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3a92b867-f870-1f45-b9d2-0fe766d95189"],
 ".\n We note that in the limit ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Alpha]", 
          StyleBox["i", "TI"]], "\[Rule]", 
         SubscriptBox["\[Alpha]", 
          StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\alpha_{i}\\rightarrow\\alpha_{j}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "93dddfd8-cdee-2d43-b86c-ced9c661ae79"],
 " ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["N", "TI"], TraditionalForm], "errors" -> {}, "input" -> "N", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "11a6de70-57bd-fa4e-888f-3d55b3063a67"],
 " becomes undefined, and our normalised wavefunction approaches ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        FractionBox["0", "0"], TraditionalForm], "errors" -> {}, "input" -> 
      "\\frac{0}{0}", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], ","}], TraditionalForm]],ExpressionUUID->
  "ca002512-ee0b-de4c-87eb-1253a04478ba"],
 " which is not well defined. This reflects the Pauli exclusion principle  \
disallowing double occupancy of states. We define any matrix element in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LeftAngleBracket]", 
         RowBox[{" ", 
           StyleBox["i", "TI"], ",", 
           StyleBox["j", "TI"], "|", 
           StyleBox["i", "TI"], ",", 
           StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i,j|i,l\\ \\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d813149f-3843-9944-93d2-0064e7df92b0"],
 " or ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LeftAngleBracket]", 
         RowBox[{" ", 
           StyleBox["i", "TI"], ",", 
           StyleBox["j", "TI"], "|", 
           StyleBox["k", "TI"], ",", 
           StyleBox["j", "TI"], " "}], "\[RightAngleBracket]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i,j|k, j\\ \\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "181cbb50-3ecc-fc43-a827-fc0634c98059"],
 " being 0.\n We now find the matrix elements for our antisymmetrized state.\n\
 Starting with the overlap element,\n ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          RowBox[{"\[LeftAngleBracket]", 
            RowBox[{" ", 
              StyleBox["i", "TI"], ",", 
              StyleBox["j", "TI"], "|", 
              StyleBox["k", "TI"], ",", 
              StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
          "\[LongEqual]", 
          SubscriptBox[
           StyleBox["N", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], 
             StyleBox["j", "TI"]}]], 
          SubscriptBox[
           StyleBox["N", "TI"], 
           RowBox[{
             StyleBox["k", "TI"], 
             StyleBox["l", "TI"]}]], 
          SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
          SuperscriptBox[
           StyleBox["d", "TI"], "3"], 
          SubscriptBox[
           OverscriptBox[
            StyleBox["r", "TI"], "\[RightVector]"], "1"], 
          SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
          SuperscriptBox[
           StyleBox["d", "TI"], "3"], 
          SubscriptBox[
           OverscriptBox[
            StyleBox["r", "TI"], "\[RightVector]"], "2"], 
          RowBox[{"(", 
            RowBox[{
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["i", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["j", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["j", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["i", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], 
            ")"}], 
          RowBox[{"(", 
            RowBox[{
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["k", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["l", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["l", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
              SubscriptBox["\[CapitalPhi]", 
               StyleBox["k", "TI"]], 
              RowBox[{"(", 
                OverscriptBox[
                 SubscriptBox[
                  StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], 
            ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
      "\\langle\\ i,j|k, l\\ \\rangle = \
N_{ij}N_{kl}\\int_{0}^{\\infty}d^{3}\\vec{r}_{1}\\int_{0}^{\\infty}d^{3}\\vec{\
r}_{2}\\left(\\Phi_{i}(\\vec{r_{1}})\\Phi_{j}(\\vec{r_{2}})-\\Phi_{j}(\\vec{r_\
{1}})\\Phi_{i}(\\vec{r_{2}})\\right)\\left(\\Phi_{k}(\\vec{r_{1}})\\Phi_{l}(\\\
vec{r_{2}})-\\Phi_{l}(\\vec{r_{1}})\\Phi_{k}(\\vec{r_{2}})\\right)", "state" -> 
      "Boxes"|>,
     "TeXAssistantTemplate"], ","}], TraditionalForm]],ExpressionUUID->
  "d150b94e-5718-c248-9dcb-344057cb0a84"],
 "\n multiplying out the brackets and using that the resulting terms are just \
the overlap elements of the symmetrized terms gives\n ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"], 
            StyleBox["l", "TI"]}], "as"], "\[LongEqual]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", "2", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["l", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["k", "TI"]}]], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["l", "TI"]}]], "-", 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["i", "TI"], 
                StyleBox["l", "TI"]}]], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]]}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["O", "TI"], 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["k", "TI"]}]], 
            SubscriptBox[
             StyleBox["O", "TI"], 
             RowBox[{
               StyleBox["j", "TI"], 
               StyleBox["l", "TI"]}]], "-", 
            SubscriptBox[
             StyleBox["O", "TI"], 
             RowBox[{
               StyleBox["i", "TI"], 
               StyleBox["l", "TI"]}]], 
            SubscriptBox[
             StyleBox["O", "TI"], 
             RowBox[{
               StyleBox["j", "TI"], 
               StyleBox["k", "TI"]}]]}], 
          SqrtBox[
           RowBox[{
             RowBox[{"(", 
               RowBox[{"1", "-", 
                 SubsuperscriptBox[
                  StyleBox["O", "TI"], 
                  RowBox[{
                    StyleBox["i", "TI"], 
                    StyleBox["j", "TI"]}], "2"]}], ")"}], "(", 
             RowBox[{"1", "-", 
               SubsuperscriptBox[
                StyleBox["O", "TI"], 
                RowBox[{
                  StyleBox["k", "TI"], 
                  StyleBox["l", "TI"]}], "2"]}], ")"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "O_{ijkl}^{\\text{as}}=\\langle\\ i,j|k, l\\ \\rangle = \
2N_{ij}N_{kl}\\left(O_{ik}O_{jl}-O_{il}O_{jk}\\right)=\\frac{O_{ik}O_{jl}-O_{\
il}O_{jk}}{\\sqrt{\\left(1-O_{ij}^{2}\\right)\\left(1-O_{kl}^{2}\\right)}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "da1189cc-4c0e-3246-829f-edbddd059612"],
 "\n \nTo evaluate the antisymmetrized core neutron potential term for the \
nth particle we start from the above and include the core neutron potential \
operator. As this only acts on one set of coordinates at a time it, like the \
case for the antisymmetrized overlap element, can be written in terms of the \
symmetrised matrix elements as follows\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
             SubsuperscriptBox[
              StyleBox["V", "TI"], "1", "cn"], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["N", "TI"], "2"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], 
         SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "2"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["j", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["i", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], ")"}], 
         SuperscriptBox[
          StyleBox["V", "TI"], "cn"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["r", "TI"], "1"], ")"}], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}], "-", 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["l", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "1"], "\[RightVector]"], ")"}], 
             SubscriptBox["\[CapitalPhi]", 
              StyleBox["k", "TI"]], 
             RowBox[{"(", 
               OverscriptBox[
                SubscriptBox[
                 StyleBox["r", "TI"], "2"], "\[RightVector]"], ")"}]}], 
           ")"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\langle\\ i,j|V_{1}^{\\text{cn}}|k,l\\ \
\\rangle=N^{2}\\int_{0}^{\\infty}d^{3}\\vec{r}_{1}\\int_{0}^{\\infty}d^{3}\\\
vec{r}_{2}\\left(\\Phi_{i}(\\vec{r_{1}})\\Phi_{j}(\\vec{r_{2}})-\\Phi_{j}(\\\
vec{r_{1}})\\Phi_{i}(\\vec{r_{2}})\\right)V^{\\text{cn}}(r_{1})\\left(\\Phi_{\
k}(\\vec{r_{1}})\\Phi_{l}(\\vec{r_{2}})-\\Phi_{l}(\\vec{r_{1}})\\Phi_{k}(\\\
vec{r_{2}})\\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8284c2f2-ba95-a241-8ad5-196fa5a3206a"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["N", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
