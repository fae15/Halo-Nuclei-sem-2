         StyleBox["d", "TI"], 
         StyleBox["r", "TI"], 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["u", "TI"], 
             StyleBox["i", "TI"]], "(", 
            StyleBox["r", "TI"], ")"}], 
          StyleBox["r", "TI"]], 
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["r", "TI"], 
             FractionBox[
              RowBox[{
                StyleBox["d", "TI"], 
