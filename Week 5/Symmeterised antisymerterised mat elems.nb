         SubscriptBox[
          StyleBox["O", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["l", "TI"]}]], ", ", 
         SubscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["h", "TI"], "2"], 
          RowBox[{"8", 
            SuperscriptBox["\[Pi]", "2"], "\[Mu]"}]], "\[Integral]", 
         SuperscriptBox[
          StyleBox["d", "TI"], "3"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "1"], 
