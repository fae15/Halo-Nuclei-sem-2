                SubscriptBox[
                 StyleBox["u", "TI"], 
                 StyleBox["k", "TI"]], "(", 
                StyleBox["r", "TI"], ")"}], 
              StyleBox["r", "TI"]]}], ")"}], "\[LongEqual]", 
