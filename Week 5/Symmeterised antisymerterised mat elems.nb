                StyleBox["i", "TI"], 
                StyleBox["l", "TI"]}]], 
             SubscriptBox[
              StyleBox["T", "TI"], 
              RowBox[{
                StyleBox["j", "TI"], 
                StyleBox["k", "TI"]}]], "-", 
             SubscriptBox[
