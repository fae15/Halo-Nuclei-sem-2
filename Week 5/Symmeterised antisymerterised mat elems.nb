               StyleBox["T", "TI"], "^"], 
              StyleBox["n", "TI"]], "|", 
             StyleBox["k", "TI"], ",", 
             StyleBox["l", "TI"], " "}], "\[RightAngleBracket]"}], 
         "\[LongEqual]", 
         SubscriptBox[
          StyleBox["N", "TI"], 
