    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2f7ab63-d142-2043-a4f0-c9802f66a101"],
 " \n\nFollowing from this we do the same for the kinetic matrix elements to \
find them as \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{" ", 
             StyleBox["i", "TI"], ",", 
             StyleBox["j", "TI"], "|", 
